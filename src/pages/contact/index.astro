---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Contact - Bandenkop">
  <!-- Hero Section avec animation -->
  <section class="relative pt-32 pb-20 bg-gradient-to-br from-orange-900 via-red-900 to-amber-900 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: url('/patterns/african-pattern.svg'); background-size: 100px;"></div>
    
    <!-- Cercles décoratifs animés -->
    <div class="absolute top-20 left-10 w-32 h-32 bg-orange-500/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-20 right-10 w-40 h-40 bg-red-500/20 rounded-full blur-3xl animate-pulse delay-1000"></div>
    
    <div class="relative container mx-auto px-6 text-center text-white">
      <div class="inline-flex items-center px-4 py-2 bg-white/10 backdrop-blur-md rounded-full mb-6 animate-fade-in">
        <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse mr-2"></span>
        <span class="text-sm font-medium">Nous contacter</span>
      </div>
      <h1 class="text-5xl md:text-7xl font-black mb-6 animate-slide-up">
        Contactez-
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-yellow-300">Nous</span>
      </h1>
      <p class="text-xl text-orange-100 max-w-3xl mx-auto animate-slide-up animation-delay-200">
        Une question ? Une suggestion ? Nous sommes à votre écoute
      </p>
    </div>
  </section>

  <!-- Formulaire de contact -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-12">
          <!-- Informations de contact avec icônes modernes -->
          <div>
            <div class="mb-8">
              <span class="text-orange-600 font-semibold text-sm uppercase tracking-wider">Informations</span>
              <h2 class="text-3xl font-bold text-gray-800 mt-2 mb-4">Entrons en contact</h2>
              <p class="text-gray-600">N'hésitez pas à nous contacter pour toute question ou suggestion. Nous vous répondrons dans les plus brefs délais.</p>
            </div>
            
            <div class="space-y-6">
              <div class="flex items-start space-x-4 group">
                <div class="w-12 h-12 bg-gradient-to-br from-orange-100 to-red-100 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-800 mb-1">Adresse</h3>
                  <p class="text-gray-600 leading-relaxed">Village Bandenkop, Arrondissement de Bangou<br>Département des Hauts Plateaux<br>Ouest Cameroun</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-4 group">
                <div class="w-12 h-12 bg-gradient-to-br from-orange-100 to-red-100 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-800 mb-1">Téléphone</h3>
                  <p class="text-gray-600">+237 678 87 80 19 (WhatsApp)</p>
                  <p class="text-xs text-gray-400">Du lundi au vendredi, 9h-17h</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-4 group">
                <div class="w-12 h-12 bg-gradient-to-br from-orange-100 to-red-100 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-800 mb-1">Email</h3>
                  <p class="text-gray-600">contact@bandenkoponline.com</p>
                  <p class="text-xs text-gray-400">Réponse sous 48h</p>
                </div>
              </div>
            </div>
            
            <!-- Réseaux sociaux avec animation -->
            <div class="mt-10 pt-6 border-t border-gray-100">
              <h3 class="font-semibold text-gray-800 mb-4">Suivez-nous</h3>
              <div class="flex space-x-3">
                <a href="https://www.facebook.com/profile.php?id=61574225576344" class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center hover:bg-gradient-to-r hover:from-orange-600 hover:to-red-600 hover:text-white transition-all duration-300 group">
                  <svg class="w-5 h-5 text-gray-600 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                </a>
                <a href="#" class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center hover:bg-gradient-to-r hover:from-orange-600 hover:to-red-600 hover:text-white transition-all duration-300 group">
                  <svg class="w-5 h-5 text-gray-600 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M18.244 2H21.5l-7.12 8.138L22.75 22h-6.55l-5.13-6.72L5.2 22H1.94l7.62-8.71L1.5 2h6.72l4.64 6.16L18.244 2Zm-1.15 18h1.81L7.27 3.89H5.33L17.094 20Z"/>
                  </svg>
                </a>
                <a href="#" class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center hover:bg-gradient-to-r hover:from-orange-600 hover:to-red-600 hover:text-white transition-all duration-300 group">
                  <svg class="w-5 h-5 text-gray-600 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2Zm0 1.8A3.95 3.95 0 0 0 3.8 7.75v8.5a3.95 3.95 0 0 0 3.95 3.95h8.5a3.95 3.95 0 0 0 3.95-3.95v-8.5a3.95 3.95 0 0 0-3.95-3.95h-8.5Zm8.95 1.45a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 1.8a3.2 3.2 0 1 0 0 6.4 3.2 3.2 0 0 0 0-6.4Z"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
          
          <!-- Formulaire amélioré -->
          <div class="bg-gray-50 rounded-2xl p-8 shadow-lg">
            <div class="mb-6">
              <span class="text-orange-600 font-semibold text-sm uppercase tracking-wider">Formulaire</span>
              <h2 class="text-2xl font-bold text-gray-800 mt-2">Envoyez-nous un message</h2>
            </div>
            
            <form class="space-y-5" id="contactForm">
              <div>
                <label class="block text-gray-700 font-medium mb-2">Nom complet</label>
                <input type="text" name="nom" required class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-all duration-300 bg-white">
              </div>
              
              <div>
                <label class="block text-gray-700 font-medium mb-2">Email</label>
                <input type="email" name="email" required class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-all duration-300 bg-white">
              </div>
              
              <div>
                <label class="block text-gray-700 font-medium mb-2">Sujet</label>
                <input type="text" name="subject" id="subject" required class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-all duration-300 bg-white">
              </div>
              
              <div>
                <label class="block text-gray-700 font-medium mb-2">Message</label>
                <textarea name="message" rows="5" required class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-all duration-300 bg-white resize-none"></textarea>
              </div>
              
              <button type="submit" class="w-full bg-gradient-to-r from-orange-600 to-red-600 text-white py-4 rounded-xl font-semibold hover:shadow-xl transform hover:scale-105 transition-all duration-300 flex items-center justify-center space-x-2 group">
                <span>Envoyer le message</span>
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </button>
            </form>
            
            <p class="text-xs text-gray-400 text-center mt-4">
              En envoyant ce formulaire, vous acceptez que vos données soient traitées pour vous répondre.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Carte interactive améliorée -->
  <section class="relative h-96 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent z-10"></div>
    <iframe 
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3979.766283563639!2d10.383333!3d5.133333!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNcKwMDgnMDAuMCJOIDEwwrAyMycwMC4wIkU!5e0!3m2!1sfr!2scm!4v1620000000000!5m2!1sfr!2scm"
      class="w-full h-full object-cover"
      style="border:0; filter: brightness(0.9);"
      allowfullscreen=""
      loading="lazy">
    </iframe>
    <div class="absolute bottom-8 left-8 z-20 bg-white/90 backdrop-blur-sm rounded-xl px-6 py-3 shadow-lg">
      <div class="flex items-center space-x-2">
        <span class="w-3 h-3 bg-red-500 rounded-full animate-pulse"></span>
        <span class="text-sm font-medium text-gray-800">Bandenkop, Cameroun</span>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { getApiUrl } from '../../config';

  async function handleSubmit(event: Event) {
    event.preventDefault();

    const form = event.target;
    if (!(form instanceof HTMLFormElement)) return;

    const nomField = form.elements.namedItem('nom');
    const emailField = form.elements.namedItem('email');
    const sujetField = form.elements.namedItem('subject');
    const messageField = form.elements.namedItem('message');

    const nom = nomField instanceof HTMLInputElement ? nomField.value.trim() : '';
    const email = emailField instanceof HTMLInputElement ? emailField.value.trim() : '';
    const subject = sujetField instanceof HTMLInputElement ? sujetField.value.trim() : '';
    const message = messageField instanceof HTMLTextAreaElement ? messageField.value.trim() : '';

    if (!nom || !email || !subject || !message) {
      alert('Veuillez remplir tous les champs.');
      return;
    }

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const originalBtnText = submitBtn?.innerHTML || '';

    try {
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span>Envoi en cours...</span>';
      }

      const API_URL = getApiUrl();
      const response = await fetch(`${API_URL}/api/contact`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nom, email, subject, message })
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data?.error || 'Erreur lors de l\'envoi');
      }

      alert('Message envoyé avec succès ! Nous vous répondrons dans les plus brefs délais. 📧');
      form.reset();
    } catch (error) {
      console.error('Erreur envoi contact:', error);
      alert('Impossible d\'envoyer le message pour le moment. Veuillez réessayer.');
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalBtnText;
      }
    }
  }

  document.getElementById('contactForm')?.addEventListener('submit', (e) => {
    void handleSubmit(e);
  });

  // Récupérer le paramètre subject dans l'URL
  const urlParams = new URLSearchParams(window.location.search);
  const subject = urlParams.get('subject');
  
  const subjectInput = document.getElementById('subject');
  if (subjectInput instanceof HTMLInputElement) {
    if (subject === 'Don') {
      subjectInput.value = 'Proposition de don';
    } else if (subject === 'Projet') {
      subjectInput.value = 'Proposition de projet';
    }
  }
</script>

<style is:global>
  .animation-delay-200 {
    animation-delay: 200ms;
  }
  
  .animate-slide-up {
    animation: slideUp 0.6s ease-out forwards;
  }
  
  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>