            <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-sm">#Histoire</span>
            <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-sm">#Bandenkop</span>
            <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-sm">#Traditions</span>
          </div>
        </div>
      </article>

      <div class="mt-8 flex justify-between">
        <a href="/histoire" class="flex items-center text-orange-600 hover:text-orange-800">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
