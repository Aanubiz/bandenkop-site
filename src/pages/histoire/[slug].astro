  <div id="lightbox" class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center" onclick="closeLightbox()">
    <div class="relative max-w-5xl max-h-[90vh] p-4" onclick="event.stopPropagation()">
      <button onclick="closeLightbox()" class="absolute -top-12 right-0 text-white text-4xl hover:text-orange-500 transition-colors">&times;</button>
      <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[85vh] mx-auto object-contain rounded-lg shadow-2xl" />
      <p id="lightbox-caption" class="text-center text-white mt-4 text-sm"></p>
      <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 flex space-x-2">
        <button onclick="zoomIn()" class="bg-white/20 hover:bg-white/30 text-white px-3 py-1 rounded-full text-sm transition">🔍 +</button>
        <button onclick="zoomOut()" class="bg-white/20 hover:bg-white/30 text-white px-3 py-1 rounded-full text-sm transition">🔍 -</button>
      </div>
    </div>
  </div>

  <ScrollToTop />

  <script>
    let liked = false;
    let likeCount = 0;
    let currentZoom = 1;
    let currentImage: HTMLImageElement | null = null;

    function openLightbox(url: string, caption: string) {
      const lightbox = document.getElementById('lightbox');
      const img = document.getElementById('lightbox-img') as HTMLImageElement | null;
      const captionEl = document.getElementById('lightbox-caption');
      if (!lightbox || !img || !captionEl) return;
      img.src = url;
      img.style.transform = "scale(1)";
      currentZoom = 1;
      captionEl.textContent = caption || '';
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
      currentImage = img;
    }

    function closeLightbox() {
      const lightbox = document.getElementById('lightbox');
      if (!lightbox) return;
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
      if (currentImage) {
        currentImage.style.transform = "scale(1)";
        currentZoom = 1;
      }
    }

    function zoomIn() {
      if (currentImage && currentZoom < 3) {
        currentZoom += 0.25;
        currentImage.style.transform = "scale(" + currentZoom + ")";
      }
    }

    function zoomOut() {
      if (currentImage && currentZoom > 0.5) {
        currentZoom -= 0.25;
        currentImage.style.transform = "scale(" + currentZoom + ")";
      }
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeLightbox();
      }
    });

    const windowWithLightbox = window as typeof window & {
      openLightbox: typeof openLightbox;
      closeLightbox: typeof closeLightbox;
      zoomIn: typeof zoomIn;
      zoomOut: typeof zoomOut;
    };
    windowWithLightbox.openLightbox = openLightbox;
    windowWithLightbox.closeLightbox = closeLightbox;
    windowWithLightbox.zoomIn = zoomIn;
    windowWithLightbox.zoomOut = zoomOut;

    const searchInput = document.getElementById('searchInput') as HTMLInputElement | null;
    const searchResults = document.getElementById('searchResults') as HTMLElement | null;
    const articleContent = document.querySelector('.article-content') as HTMLElement | null;

    interface SearchResult {
      node: Text;
      start: number;
      end: number;
      text: string;
    }

    function searchInArticle() {
      if (!searchInput || !searchResults || !articleContent) return;
      const searchTerm = searchInput.value.trim().toLowerCase();
      if (!searchTerm || searchTerm.length < 2) {
        searchResults.classList.add('hidden');
        clearHighlights();
        return;
      }

      const textNodes = getTextNodes(articleContent);
      const results: SearchResult[] = [];
      textNodes.forEach(function(node: Text) {
        const raw = node.textContent || '';
        const text = raw.toLowerCase();
        let index = text.indexOf(searchTerm);
        while (index !== -1) {
          results.push({
            node: node,
            start: index,
            end: index + searchTerm.length,
            text: raw.substring(Math.max(0, index - 50), Math.min(raw.length, index + searchTerm.length + 50))
          });
          index = text.indexOf(searchTerm, index + 1);
        }
      });

      if (results.length > 0) {
        searchResults.innerHTML = results.slice(0, 10).map(function(result, i) {
          return '<div class="p-3 hover:bg-orange-50 cursor-pointer border-b border-gray-100 last:border-0 search-result-item" data-index="' + i + '">' +
            '<p class="text-sm text-gray-600">...' + result.text.replace(new RegExp(searchTerm, 'gi'), function(match: string) { return '<mark class="bg-yellow-200">' + match + '</mark>'; }) + '...</p>' +
            '</div>';
        }).join('');
        searchResults.classList.remove('hidden');
        
        document.querySelectorAll('.search-result-item').forEach(function(item, idx) {
          item.addEventListener('click', function() {
            const result = results[idx];
            if (!result) return;
            const range = document.createRange();
            range.setStart(result.node, result.start);
            range.setEnd(result.node, result.end);
            const span = document.createElement('span');
            span.appendChild(range.extractContents());
            range.insertNode(span);
            span.scrollIntoView({ behavior: 'smooth', block: 'center' });
            span.classList.add('bg-yellow-200', 'transition-all', 'duration-1000');
            setTimeout(function() { span.classList.remove('bg-yellow-200'); }, 3000);
          });
        });
        highlightText(searchTerm);
      } else {
        searchResults.innerHTML = '<div class="p-3 text-sm text-gray-500">Aucun résultat trouvé</div>';
        searchResults.classList.remove('hidden');
        clearHighlights();
      }
    }

    function getTextNodes(node: Node): Text[] {
      const textNodes: Text[] = [];
      function getNodes(n: Node) {
        if (n.nodeType === Node.TEXT_NODE && (n.textContent || '').trim().length > 0) {
          textNodes.push(n as Text);
        } else if (n.nodeType === Node.ELEMENT_NODE) {
          const el = n as Element;
          if (el.tagName !== 'SCRIPT' && el.tagName !== 'STYLE') {
            n.childNodes.forEach(function(child: Node) { getNodes(child); });
          }
        }
      }
      getNodes(node);
      return textNodes;
    }

    function highlightText(searchTerm: string) {
      if (!articleContent) return;
      clearHighlights();
      const walker = document.createTreeWalker(articleContent, NodeFilter.SHOW_TEXT, {
        acceptNode: function(node: Node) {
          if ((node as Text).parentElement && (node as Text).parentElement?.tagName === 'MARK') return NodeFilter.FILTER_REJECT;
          if ((node.textContent || '').trim().length === 0) return NodeFilter.FILTER_REJECT;
          return NodeFilter.FILTER_ACCEPT;
        }
      });
      const textNodes: Text[] = [];
      while (walker.nextNode()) textNodes.push(walker.currentNode as Text);
      textNodes.forEach(function(node: Text) {
        const text = node.textContent || '';
        const regex = new RegExp('(' + searchTerm + ')', 'gi');
        if (regex.test(text)) {
          const span = document.createElement('span');
          span.innerHTML = text.replace(regex, '<mark class="bg-yellow-200">$1</mark>');
          node.parentNode?.replaceChild(span, node);
        }
      });
    }

    function clearHighlights() {
      if (!articleContent) return;
      const marks = articleContent.querySelectorAll('mark');
      marks.forEach(function(mark) {
        const parent = mark.parentNode;
        if (!parent) return;
        parent.replaceChild(document.createTextNode(mark.textContent || ''), mark);
        if (parent.normalize) parent.normalize();
      });
    }

    searchInput?.addEventListener('input', function() { setTimeout(searchInArticle, 100); });
    document.addEventListener('click', function(e) {
      const target = e.target as Node | null;
      if (!searchInput?.contains(target) && !searchResults?.contains(target)) {
        searchResults?.classList.add('hidden');
      }
    });

    document.getElementById("likeBtn")?.addEventListener("click", function() {
      const likeIcon = document.getElementById("likeIcon");
      const likeCountEl = document.getElementById("likeCount");
      if (!likeIcon || !likeCountEl) return;
      if (!liked) {
        likeIcon.classList.remove("text-gray-400");
        likeIcon.classList.add("text-red-600", "fill-current");
        likeIcon.style.fill = "#ef4444";
        likeCount++;
        liked = true;
      } else {
        likeIcon.classList.add("text-gray-400");
        likeIcon.classList.remove("text-red-600", "fill-current");
        likeIcon.style.fill = "none";
        likeCount--;
        liked = false;
      }
      likeCountEl.textContent = String(likeCount);
      likeIcon.classList.add("animate-pulse");
      setTimeout(function() { likeIcon.classList.remove("animate-pulse"); }, 300);
    });

    document.getElementById("shareBtn")?.addEventListener("click", async function() {
      if (navigator.share) {
        await navigator.share({ title: document.title, url: window.location.href });
      } else {
        await navigator.clipboard.writeText(window.location.href);
        alert("🔗 Lien copié !");
      }
    });

    document.getElementById("printBtn")?.addEventListener("click", function() { window.print(); });
  </script>

  <style is:global>
    .article-content { font-family: 'Georgia', 'Times New Roman', serif; line-height: 1.8; color: #374151; }
    .article-content p { margin-bottom: 1.5rem; font-size: 1.125rem; text-align: justify; }
    .article-content h3 { font-family: "Playfair Display", serif; font-size: 1.5rem; margin-top: 2rem; margin-bottom: 1rem; color: #1f2937; border-left: 4px solid #f97316; padding-left: 1rem; }
    .article-content blockquote { position: relative; font-style: italic; border-left: 6px solid #f97316; padding: 1.5rem 2rem; margin: 2rem 0; color: #4b5563; background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%); border-radius: 1rem; font-size: 1.1rem; line-height: 1.6; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06); }
    .article-content blockquote::before { content: "“"; font-size: 4rem; font-family: Georgia, serif; position: absolute; top: -0.5rem; left: 0.5rem; color: #f97316; opacity: 0.3; }
    .article-content blockquote::after { content: "”"; font-size: 4rem; font-family: Georgia, serif; position: absolute; bottom: -2rem; right: 1rem; color: #f97316; opacity: 0.3; }
    .article-content blockquote cite { display: block; margin-top: 1rem; font-size: 0.875rem; color: #b45309; font-style: normal; font-weight: 500; text-align: right; border-top: 1px solid #fed7aa; padding-top: 0.75rem; }
    .article-content blockquote cite::before { content: "— "; }
    .article-content blockquote:hover { transform: translateX(4px); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); transition: all 0.2s ease; }
    #lightbox { backdrop-filter: blur(5px); transition: all 0.3s ease; }
    #lightbox-img { transition: transform 0.2s ease; }
    .article-content .tap-hint {
      font-family: Inter, "Helvetica Neue", Arial, sans-serif !important;
      font-weight: 300 !important;
      font-size: 8px !important;
      line-height: 1.1 !important;
      letter-spacing: 0.01em;
      color: #ea580c !important;
      margin-top: 0.25rem !important;
      margin-bottom: 0 !important;
      text-align: center;
      font-style: normal !important;
    }
    .article-content .photo-caption {
      font-family: "Fira Sans", Inter, "Helvetica Neue", Arial, sans-serif !important;
      font-weight: 500 !important;
      font-size: 10px !important;
      line-height: 1.2 !important;
      color: #0f766e !important;
      margin-top: 0.25rem !important;
      margin-bottom: 0 !important;
      text-align: center !important;
      font-style: normal !important;
    }
    #lightbox-caption {
      font-family: "Fira Sans", Inter, "Helvetica Neue", Arial, sans-serif !important;
      font-weight: 500 !important;
      color: #99f6e4 !important;
      text-align: center !important;
      letter-spacing: 0.01em;
    }
    .article-content .chiefs-scroll {
      display: flex;
      gap: 0.75rem;
      overflow-x: auto;
      overflow-y: hidden;
      padding: 0.25rem 0.1rem 0.65rem;
      margin: 0.75rem 0 1.25rem;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
    }
    .article-content .chiefs-scroll__item {
      flex: 0 0 112px;
      scroll-snap-align: start;
    }
    .article-content .chiefs-scroll::-webkit-scrollbar {
      height: 6px;
    }
    .article-content .chiefs-scroll::-webkit-scrollbar-thumb {
      background: #cbd5e1;
      border-radius: 999px;
    }
    .article-content .chiefs-scroll::-webkit-scrollbar-track {
      background: #f1f5f9;
      border-radius: 999px;
    }
    @media (min-width: 640px) {
      .article-content .photo-caption {
        font-size: 12px !important;
        margin-top: 0.5rem !important;
      }
      .article-content .chiefs-scroll__item {
        flex-basis: 150px;
      }
    }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    #lightbox { animation: fadeIn 0.2s ease-out; }
    @media (max-width: 640px) {
      .article-content p { font-size: 1rem; }
      .article-content h3 { font-size: 1.25rem; }
      .article-content blockquote { padding: 1rem 1.5rem; }
      .article-content blockquote::before, .article-content blockquote::after { font-size: 2.5rem; }
      .float-left { float: left !important; width: 32% !important; min-width: 88px; margin: 0.35rem 0.75rem 0.45rem 0 !important; }
      .float-right { float: right !important; width: 32% !important; min-width: 88px; margin: 0.35rem 0 0.45rem 0.75rem !important; }
    }
    @media print {
      header, footer, .sticky, #likeBtn, #shareBtn, #printBtn, #searchInput, #searchResults, #lightbox { display: none !important; }
      article { box-shadow: none; padding: 0; }
      .article-content blockquote { background: none; border-left: 3px solid #f97316; padding: 0.5rem 1rem; box-shadow: none; }
      .article-content blockquote::before, .article-content blockquote::after { display: none; }
    }
  </style>
</Layout>