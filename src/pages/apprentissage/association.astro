---
import Layout from '../../layouts/Layout.astro';
import AuthCheck from '../../components/AuthCheck.astro';
---

<Layout title="Association FR/Bandenkop - Apprentissage">
  <AuthCheck>
    <div class="min-h-screen bg-gradient-to-br from-yellow-50 to-amber-50">
      <header class="bg-white shadow-sm sticky top-0 z-10">
        <div class="px-4 max-w-4xl mx-auto h-16 flex items-center justify-between">
          <a href="/apprentissage" class="flex items-center text-gray-600 hover:text-amber-600">
            <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Retour
          </a>
          <h1 class="text-lg font-semibold text-gray-800">Association FR ↔ Bandenkop</h1>
          <div class="w-20"></div>
        </div>
      </header>

      <div class="px-4 py-6 max-w-4xl mx-auto">
        <div id="loading" class="text-center py-12">
          <div class="inline-block animate-spin rounded-full h-8 w-8 border-4 border-amber-600 border-t-transparent"></div>
          <p class="mt-4 text-gray-600">Chargement du bloc...</p>
        </div>

        <div id="game" class="hidden space-y-6">
          <div class="bg-white rounded-xl shadow-sm p-4">
            <div class="flex items-center justify-between mb-3">
              <span id="counter" class="text-sm text-gray-500">Bloc 1</span>
              <span id="niveau" class="px-2 py-1 bg-amber-100 text-amber-700 rounded-full text-xs">Débutant</span>
            </div>
            <div class="h-2 bg-gray-200 rounded-full overflow-hidden">
              <div id="progress" class="h-full bg-gradient-to-r from-amber-500 to-orange-500 transition-all duration-300" style="width: 0%"></div>
            </div>
          </div>

          <div class="bg-white rounded-2xl shadow-lg p-6">
            <p class="text-gray-800 font-semibold mb-4">Cliquez pour associer les mots</p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <h3 class="text-sm font-bold text-gray-700 mb-2">Français</h3>
                <div id="fr-list" class="space-y-2"></div>
              </div>
              <div>
                <h3 class="text-sm font-bold text-gray-700 mb-2">Bandenkop</h3>
                <div id="bk-list" class="space-y-2"></div>
              </div>
            </div>

            <div id="pairs-view" class="mt-5 p-3 rounded-lg bg-amber-50 text-sm text-gray-700"></div>

            <button id="submit-block" disabled class="mt-4 w-full bg-gradient-to-r from-amber-600 to-orange-600 text-white py-3 rounded-xl font-semibold disabled:opacity-50">
              Valider
            </button>

            <div id="feedback" class="hidden mt-4 rounded-lg p-3 text-sm"></div>
          </div>
        </div>

        <div id="end" class="hidden bg-white rounded-2xl shadow-xl p-8 text-center">
          <h2 id="end-title" class="text-2xl font-bold text-gray-800 mb-2">Bloc terminé</h2>
          <p id="end-text" class="text-gray-600 mb-4"></p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <button id="continue-btn" class="hidden bg-amber-600 text-white px-6 py-3 rounded-xl">Continuer</button>
            <button id="restart-btn" class="bg-gray-700 text-white px-6 py-3 rounded-xl">Recommencer</button>
            <a href="/apprentissage" class="bg-gray-200 text-gray-800 px-6 py-3 rounded-xl">Retour apprentissage</a>
          </div>
        </div>
      </div>
    </div>
  </AuthCheck>

  <script>
    import { initAssociationApp } from '../../scripts/apprentissage-association';

    document.addEventListener('DOMContentLoaded', initAssociationApp);
  </script>
</Layout>
