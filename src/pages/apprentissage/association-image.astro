---
import Layout from '../../layouts/Layout.astro';
import AuthCheck from '../../components/AuthCheck.astro';
---

<Layout title="Association icône FR/BK - Apprentissage">
  <AuthCheck>
    <div class="min-h-screen bg-gradient-to-br from-amber-50 to-orange-50">
      <header class="bg-white shadow-sm sticky top-0 z-10">
        <div class="px-4 max-w-4xl mx-auto h-16 flex items-center justify-between">
          <a href="/apprentissage" class="flex items-center text-gray-600 hover:text-amber-600">
            <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Retour
          </a>
          <h1 class="text-lg font-semibold text-gray-800">Association icône FR ↔ BK</h1>
          <div id="score" class="text-sm text-orange-700 font-semibold">0 pts</div>
        </div>
      </header>

      <div class="px-4 py-6 max-w-4xl mx-auto">
        <div class="bg-white rounded-xl shadow-sm p-4 mb-4 flex items-center justify-between">
          <span id="selected-count" class="text-sm text-gray-500">0/3</span>
          <span id="niveau" class="px-2 py-1 rounded-full text-xs bg-amber-100 text-amber-700">debutant</span>
        </div>

        <div id="game" class="bg-white rounded-2xl shadow-lg p-6">
          <p class="text-gray-800 font-semibold mb-5">Sélectionne un mot français, une icône et un mot Bandenkop pour former chaque triplet (3 au total).</p>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <h3 class="text-sm font-bold text-gray-700 mb-2">Français</h3>
              <div id="fr-list" class="space-y-2"></div>
            </div>

            <div>
              <h3 class="text-sm font-bold text-gray-700 mb-2">Icônes</h3>
              <div id="icon-list" class="space-y-2"></div>
            </div>

            <div>
              <h3 class="text-sm font-bold text-gray-700 mb-2">Bandenkop</h3>
              <div id="bk-list" class="space-y-2"></div>
            </div>
          </div>

          <div class="mt-6">
            <button id="btn-validate" class="w-full bg-amber-600 text-white py-3 rounded-xl font-semibold hover:bg-amber-700 disabled:opacity-50" disabled>
              Valider les 3 triplets
            </button>
          </div>

          <div id="feedback" class="hidden mt-4 rounded-lg p-3 text-sm"></div>
        </div>

        <div id="end" class="hidden bg-white rounded-2xl shadow-xl p-8 text-center mt-4">
          <h2 class="text-2xl font-bold text-gray-800 mb-2">Bloc terminé</h2>
          <p id="end-text" class="text-gray-600 mb-4"></p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <button id="btn-next" class="hidden bg-amber-600 text-white px-6 py-3 rounded-xl">Continuer (3 suivantes)</button>
            <button id="btn-restart" class="bg-gray-700 text-white px-6 py-3 rounded-xl">Recommencer</button>
            <a href="/apprentissage" class="bg-gray-200 text-gray-800 px-6 py-3 rounded-xl">Retour apprentissage</a>
          </div>
        </div>
      </div>
    </div>
  </AuthCheck>

  <script>
    import { initAssociationImageApp } from '../../scripts/apprentissage-association-image';

    document.addEventListener('DOMContentLoaded', initAssociationImageApp);
  </script>
</Layout>
