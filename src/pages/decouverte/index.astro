---
import Layout from '../../layouts/Layout.astro';

const lieux = [
  {
    nom: "Loung Beli",
    slug: "rocher",
    type: "Relief",
    description: "Paysage de rochers granitiques offrant une vue panoramique sur toute la région",
    image: "/images/decouverte/loung_beli2.jpg",
    activites: ["Randonnée", "Observation", "Méditation"],
    saison: "Toute l'année"
  },
  {
    nom: "Centre touristique de Bandenkop",
    slug: "centre",
    type: "Tourisme",
    description: "Point culminant à 1800m d'altitude offrant une vue panoramique sur toute la région et les villages environnants",
    image: "/images/decouverte/entree_chefferie.jpg",
    activites: ["Méditation", "Pique-nique", "Photographie"],
    saison: "Saison pluvieuse"
  },
  {
    nom: "Chefferie",
    slug: "chefferie",
    type: "Culture",
    description: "Lieu de residence de Sa majesté et siège du pouvoir traditionnel.",
    image: "/images/decouverte/visite_chefferie.jpg",
    activites: ["Visite guidée", "Rencontres", "Cérémonies"],
    saison: "Toute l'année"
  },
  {
    nom: "Marché",
    slug: "marche",
    type: "Economie",
    description: "Le cœur battant du commerce local tous les Liegang.",
    image: "/images/decouverte/place_marche.jpg",
    activites: ["Commerce", "Cérémonies", "Dégustation"],
    saison: "Sur autorisation"
  },
  {
    nom: "Les chutes de Zazalieu",
    slug: "chutes",
    type: "Sacré",
    description: "Lieu hautement spirituel sous la protection des esprits ancestraux, interdit aux visiteurs.",
    image: "/images/decouverte/zazalieu.jpg",
    activites: ["Offrande", "Purification", "Mémoire"],
    saison: "Aucune visite autorisée"
  },
  {
    nom: "Lac Tcha-Tcha",
    slug: "lac",
    type: "Agriculture",
    description: "Lac naturel entouré d'eucalyptus, source d'eau pour les cultures et lieu de détente.",
    image: "/images/decouverte/tcha_tcha.jpg",
    activites: ["Détente", "Agriculture", "Pêche"],
    saison: "Toute l'année"
  }
];
---

<Layout title="Découvrir Bandenkop">
  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 bg-gradient-to-br from-orange-900 via-red-900 to-amber-900">
    <div class="absolute inset-0 opacity-10 bg-pattern"></div>
    <div class="relative container mx-auto px-6">
      <h1 class="text-5xl md:text-7xl font-black text-white text-center mb-6 animate-slide-up">
        Découvrez <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-yellow-300">Bandenkop</span>
      </h1>
      <p class="text-xl text-orange-100 text-center max-w-3xl mx-auto">
        Explorez la géographie, les richesses naturelles et culturelles de notre village
      </p>
    </div>
  </section>

  <!-- Carte interactive -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6">
      <div class="relative h-96 rounded-2xl overflow-hidden shadow-2xl mb-8">
        <img src="/images/decouverte/carte.jpg" alt="Carte de Bandenkop" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
        <div class="absolute bottom-8 left-8 text-white">
          <h2 class="text-3xl font-bold mb-2">Situation Géographique</h2>
          <p class="text-lg">Hauts Plateaux de l'Ouest Cameroun</p>
          <p class="text-sm opacity-75">Arrondissement de Bangou • 5.1333° N, 10.3833° E</p>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-orange-50 rounded-xl p-6">
          <h3 class="font-bold text-gray-800 mb-2">Superficie</h3>
          <p class="text-2xl text-orange-600">~25 km²</p>
        </div>
        <div class="bg-orange-50 rounded-xl p-6">
          <h3 class="font-bold text-gray-800 mb-2">Altitude</h3>
          <p class="text-2xl text-orange-600">1400-1800 m</p>
        </div>
        <div class="bg-orange-50 rounded-xl p-6">
          <h3 class="font-bold text-gray-800 mb-2">Population</h3>
          <p class="text-2xl text-orange-600">~40 000 hab. (85% à l'extérieur)</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Grille des lieux -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-6">
      <h2 class="text-3xl font-bold text-center text-gray-800 mb-12">Lieux à découvrir</h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {lieux.map((lieu) => (
          <a 
            href={`/decouverte/${lieu.slug}`}
            class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transform hover:scale-105 transition-all duration-500 block"
          >
            <div class="relative h-48">
              <img src={lieu.image} alt={lieu.nom} class="w-full h-full object-cover" />
              <div class="absolute top-4 left-4">
                <span class="bg-orange-600 text-white px-3 py-1 rounded-full text-sm">
                  {lieu.type}
                </span>
              </div>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-800 mb-2">{lieu.nom}</h3>
              <p class="text-gray-600 text-sm mb-4">{lieu.description}</p>
              
              <div class="mb-4">
                <h4 class="text-sm font-semibold text-gray-700 mb-2">Activités :</h4>
                <div class="flex flex-wrap gap-2">
                  {lieu.activites.map((activite) => (
                    <span class="bg-orange-100 text-orange-800 px-2 py-1 rounded-full text-xs">
                      {activite}
                    </span>
                  ))}
                </div>
              </div>
              
              <div class="flex items-center justify-between text-sm">
                <span class="text-gray-500">
                  <span class="font-semibold">Meilleure saison:</span> {lieu.saison}
                </span>
                <span class="text-orange-600 font-semibold group-hover:translate-x-1 transition-transform">
                  Détails →
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Informations pratiques -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6">
      <h2 class="text-3xl font-bold text-center text-gray-800 mb-12">Informations pratiques</h2>
      
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Climat -->
        <div class="bg-gradient-to-br from-blue-50 to-cyan-50 rounded-2xl p-6">
          <div class="text-3xl mb-3">🌤️</div>
          <h3 class="text-xl font-bold mb-4">Climat</h3>
          <ul class="space-y-2">
            <li class="flex justify-between">
              <span>Saison sèche</span>
              <span class="font-semibold">Novembre - Février</span>
            </li>
            <li class="flex justify-between">
              <span>Saison pluvieuse</span>
              <span class="font-semibold">Mars - Octobre</span>
            </li>
            <li class="flex justify-between">
              <span>Température moyenne</span>
              <span class="font-semibold">22°C</span>
            </li>
            <li class="flex justify-between">
              <span>Précipitations</span>
              <span class="font-semibold">1800 mm/an</span>
            </li>
          </ul>
        </div>

        <!-- Économie -->
        <div class="bg-gradient-to-br from-green-50 to-emerald-50 rounded-2xl p-6">
          <div class="text-3xl mb-3">💰</div>
          <h3 class="text-xl font-bold mb-4">Vie économique</h3>
          <ul class="space-y-2">
            <li class="flex justify-between">
              <span>Agriculture</span>
              <span class="font-semibold">60%</span>
            </li>
            <li class="flex justify-between">
              <span>Élevage</span>
              <span class="font-semibold">15%</span>
            </li>
            <li class="flex justify-between">
              <span>Commerce</span>
              <span class="font-semibold">18%</span>
            </li>
            <li class="flex justify-between">
              <span>Artisanat</span>
              <span class="font-semibold">2%</span>
            </li>
            <li class="flex justify-between">
              <span>Autre</span>
              <span class="font-semibold">5%</span>
            </li>
          </ul>
        </div>

        <!-- Éducation -->
        <div class="bg-gradient-to-br from-purple-50 to-pink-50 rounded-2xl p-6">
          <div class="text-3xl mb-3">📚</div>
          <h3 class="text-xl font-bold mb-4">Éducation</h3>
          <ul class="space-y-2">
            <li>• École primaire publique</li>
            <li>• Collège & Lycée</li>
            <li>• Centre de formation professionnelle</li>
            <li>• Taux de scolarisation : 90%</li>
          </ul>
        </div>

        <!-- Santé -->
        <div class="bg-gradient-to-br from-red-50 to-orange-50 rounded-2xl p-6">
          <div class="text-3xl mb-3">🏥</div>
          <h3 class="text-xl font-bold mb-4">Santé</h3>
          <ul class="space-y-2">
            <li>• Centre du centre & Centre de santé de Sin Tsèla</li>
            <li>• Maternité</li>
            <li>• Pharmacie</li>
            <li>• Médecine traditionnelle</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Activités touristiques -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="bg-gradient-to-r from-orange-600 to-red-600 rounded-2xl p-8 text-white">
        <h2 class="text-3xl font-bold text-center mb-8">Activités touristiques</h2>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="text-center">
            <span class="text-4xl block mb-3">🥾</span>
            <h3 class="font-bold mb-2">Randonnées</h3>
            <p class="text-sm opacity-90">Sentiers balisés</p>
          </div>
           <div class="text-center">
            <span class="text-4xl block mb-3">🌿</span>
            <h3 class="font-bold mb-2">Observation</h3>
            <p class="text-sm opacity-90">Le Paysage de Dengou</p>
          </div>
          <div class="text-center">
            <span class="text-4xl block mb-3">🏕️</span>
            <h3 class="font-bold mb-2">Camping</h3>
            <p class="text-sm opacity-90">Loung Beli, sites aménagés</p>
          </div>
          <div class="text-center">
            <span class="text-4xl block mb-3">🎨</span>
            <h3 class="font-bold mb-2">Artisanat</h3>
            <p class="text-sm opacity-90">Musé de Bandenkop</p>
          </div>
          <div class="text-center">
            <span class="text-4xl block mb-3">🍲</span>
            <h3 class="font-bold mb-2">Cuisine</h3>
            <p class="text-sm opacity-90">Dégustation de plats traditionnels</p>
          </div>
          <div class="text-center">
            <span class="text-4xl block mb-3">🎭</span>
            <h3 class="font-bold mb-2">Spectacles</h3>
            <p class="text-sm opacity-90">Danses traditionnels</p>
          </div>
          <div class="text-center">
            <span class="text-4xl block mb-3">📸</span>
            <h3 class="font-bold mb-2">Photographie</h3>
            <p class="text-sm opacity-90">Paysages et scènes de vie</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>