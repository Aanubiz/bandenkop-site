---
import Layout from '../../layouts/Layout.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';

const { id } = Astro.params;

// Récupérer l'article depuis l'API
const API_URL = 'http://localhost:3001';
let article = null;
let error = null;

function formaterContenu(contenu: string): string {
  if (!contenu) return '';
  
  let formatted = contenu;
  
  // Supprimer les divs "Image uploadée" indésirables
  formatted = formatted.replace(/<div[^>]*class="[^"]*float-[^"]*"[^>]*>[\s\S]*?<img[^>]*>[\s\S]*?<div[^>]*class="img-caption"[^>]*>.*?<\/div>[\s\S]*?<\/div>/gi, (match) => {
    const imgMatch = match.match(/<img[^>]*>/i);
    return imgMatch ? imgMatch[0] : match;
  });
  
  // Supprimer les légendes indésirables
  formatted = formatted.replace(/<div[^>]*class="img-caption"[^>]*>.*?<\/div>/gi, '');
  
  // Standardiser les images avec des dimensions fixes
  formatted = formatted.replace(/<img([^>]*)>/gi, (match, attrs) => {
    let hasClass = /class=["']([^"']*)["']/i.test(attrs);
    let newAttrs = attrs;
    
    if (hasClass) {
      newAttrs = attrs.replace(/class=["']([^"']*)["']/i, (match: string, classes: string) => {
        if (!classes.includes('article-img')) {
          return `class="${classes} article-img"`;
        }
        return match;
      });
    } else {
      newAttrs = attrs + ' class="article-img"';
    }
    
    newAttrs = newAttrs.replace(/style=["'][^"']*["']/i, '');
    
    return `<img${newAttrs} style="max-width: 100%; height: auto; border-radius: 0.75rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);" loading="lazy" />`;
  });
  
  // S'assurer que les images flottantes ont les bonnes dimensions
  formatted = formatted.replace(/<img[^>]*class="[^"]*float-left[^"]*"[^>]*>/gi, (match) => {
    return match.replace(/style=["'][^"']*["']/i, 'style="max-width: 300px; width: 100%; height: auto; float: left; margin: 0 1.5rem 1rem 0; border-radius: 0.75rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);"');
  });
  
  formatted = formatted.replace(/<img[^>]*class="[^"]*float-right[^"]*"[^>]*>/gi, (match) => {
    return match.replace(/style=["'][^"']*["']/i, 'style="max-width: 300px; width: 100%; height: auto; float: right; margin: 0 0 1rem 1.5rem; border-radius: 0.75rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);"');
  });
  
  formatted = formatted.replace(/<img[^>]*class="[^"]*float-center[^"]*"[^>]*>/gi, (match) => {
    return match.replace(/style=["'][^"']*["']/i, 'style="max-width: 100%; width: auto; max-height: 400px; display: block; margin: 1.5rem auto; border-radius: 0.75rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);"');
  });
  
  return formatted;
}

try {
  const response = await fetch(`${API_URL}/api/articles/${id}`);
  if (response.ok) {
    article = await response.json();
  } else {
    error = 'Article non trouvé';
  }
} catch (err) {
  console.error('Erreur chargement article:', err);
  error = 'Erreur de connexion au serveur';
}

if (!article || error) {
  return new Response(null, {
    status: 404,
    statusText: error || 'Article non trouvé'
  });
}
---

<Layout title={`${article.titre} - Actualités Bandenkop`}>
  <div class="min-h-screen bg-gray-50">
    <!-- Header avec image de couverture - AJOUT D'UN PADDING TOP -->
    <div class="relative h-96 bg-gradient-to-br from-orange-900 to-red-900 overflow-hidden mt-16 sm:mt-20">
      <div class="absolute inset-0 bg-black/40"></div>
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="text-center text-white z-10 px-4">
          <span class="inline-block px-4 py-1 bg-orange-600 rounded-full text-sm mb-4">{article.categorie}</span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4">{article.titre}</h1>
          <p class="text-xl text-orange-200">{new Date(article.datePublication).toLocaleDateString('fr-FR', {
            day: 'numeric',
            month: 'long',
            year: 'numeric'
          })}</p>
          <p class="text-sm text-orange-300 mt-2">Par {article.auteur}</p>
        </div>
      </div>
    </div>

    <!-- Contenu principal -->
    <div class="max-w-4xl mx-auto px-4 py-12">
      <!-- Barre d'outils -->
      <div class="sticky top-24 z-20 mb-8 flex justify-end">
        <div class="bg-white rounded-full shadow-lg p-2 flex items-center space-x-2">
          <button id="shareBtn" class="p-2 hover:bg-orange-100 rounded-full transition-colors" title="Partager">
            <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path>
            </svg>
          </button>
          <button id="printBtn" class="p-2 hover:bg-orange-100 rounded-full transition-colors" title="Imprimer">
            <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path>
            </svg>
          </button>
        </div>
      </div>

      <!-- Article avec mise en page de magazine -->
      <article class="bg-white rounded-2xl shadow-xl p-8 md:p-12 overflow-hidden">
        <!-- Image principale - PLEINE LARGEUR AVEC EFFET COVER -->
        {article.image && (
          <div class="article-main-image mb-8 -mt-8 md:-mt-12">
            <img 
              src={article.image} 
              alt={article.titre} 
              class="w-full h-64 sm:h-80 md:h-96 object-cover"
              loading="eager"
              onerror="this.style.display='none'"
            />
          </div>
        )}

        <!-- Contenu formaté -->
        <div class="article-content prose prose-lg max-w-none" set:html={formaterContenu(article.contenu)} />
        
        <!-- Tags -->
        {article.tags && article.tags.length > 0 && (
          <div class="mt-8 pt-4 border-t border-gray-100">
            <div class="flex flex-wrap gap-2">
              {article.tags.map((tag: string) => (
                <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-sm">#{tag}</span>
              ))}
            </div>
          </div>
        )}
      </article>

      <!-- Navigation -->
      <div class="mt-8 flex justify-between">
        <a href="/actualite" class="flex items-center text-orange-600 hover:text-orange-800">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Retour aux actualités
        </a>
      </div>
    </div>
  </div>

  <ScrollToTop />

  <script>
    document.getElementById('shareBtn')?.addEventListener('click', async () => {
      if (navigator.share) {
        try {
          await navigator.share({
            title: document.title,
            url: window.location.href
          });
        } catch (err) {
          console.log('Partage annulé');
        }
      } else {
        await navigator.clipboard.writeText(window.location.href);
        alert('🔗 Lien copié dans le presse-papier !');
      }
    });

    document.getElementById('printBtn')?.addEventListener('click', () => {
      window.print();
    });
  </script>

  <style is:global>
    /* Styles pour l'article */
    .article-content {
      font-family: 'Georgia', 'Times New Roman', serif;
      line-height: 1.8;
      color: #1f2937;
      overflow-x: hidden;
    }

    .article-content p {
      margin-bottom: 1.5rem;
      font-size: 1.125rem;
    }

    .article-content h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.8rem;
      margin-top: 2rem;
      margin-bottom: 1rem;
      color: #1f2937;
      border-bottom: 2px solid #f97316;
      padding-bottom: 0.5rem;
      display: inline-block;
    }

    .article-content h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      margin-top: 1.5rem;
      margin-bottom: 0.75rem;
      color: #374151;
    }

    /* ===== IMAGE PRINCIPALE PLEINE LARGEUR ===== */
    .article-main-image {
      margin-left: -2rem;
      margin-right: -2rem;
      width: calc(100% + 4rem);
      overflow: hidden;
    }
    
    @media (min-width: 640px) {
      .article-main-image {
        margin-left: -2rem;
        margin-right: -2rem;
        width: calc(100% + 4rem);
      }
    }
    
    @media (min-width: 768px) {
      .article-main-image {
        margin-left: -3rem;
        margin-right: -3rem;
        width: calc(100% + 6rem);
      }
    }
    
    @media (min-width: 1024px) {
      .article-main-image {
        margin-left: -4rem;
        margin-right: -4rem;
        width: calc(100% + 8rem);
      }
    }
    
    .article-main-image img {
      width: 100%;
      height: 16rem;
      object-fit: cover;
    }
    
    @media (min-width: 640px) {
      .article-main-image img {
        height: 20rem;
      }
    }
    
    @media (min-width: 768px) {
      .article-main-image img {
        height: 24rem;
      }
    }

    /* Style pour les citations */
    .article-content blockquote {
      position: relative;
      font-style: italic;
      border-left: 4px solid #f97316;
      padding: 1.5rem 2rem;
      margin: 2rem 0;
      color: #4b5563;
      background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
      border-radius: 1rem;
      font-size: 1.2rem;
      line-height: 1.6;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .article-content blockquote::before {
      content: "“";
      font-size: 4rem;
      font-family: Georgia, serif;
      position: absolute;
      top: -0.5rem;
      left: 0.5rem;
      color: #f97316;
      opacity: 0.3;
    }

    .article-content blockquote::after {
      content: "”";
      font-size: 4rem;
      font-family: Georgia, serif;
      position: absolute;
      bottom: -2rem;
      right: 1rem;
      color: #f97316;
      opacity: 0.3;
    }

    .article-content blockquote cite {
      display: block;
      margin-top: 1rem;
      font-size: 0.875rem;
      color: #b45309;
      font-style: normal;
      font-weight: 500;
      text-align: right;
      border-top: 1px solid #fed7aa;
      padding-top: 0.75rem;
    }

    /* Images flottantes */
    .article-content .float-left {
      float: left;
      max-width: 300px;
      width: 100%;
      margin: 0 1.5rem 1rem 0;
    }

    .article-content .float-right {
      float: right;
      max-width: 300px;
      width: 100%;
      margin: 0 0 1rem 1.5rem;
    }

    .article-content .float-center {
      display: block;
      margin: 1.5rem auto;
      text-align: center;
      max-width: 100%;
    }

    .article-content .float-center img {
      max-width: 100%;
      max-height: 400px;
      width: auto;
      margin: 0 auto;
    }

    .article-content img.article-img,
    .article-content img:not(.article-main-image img) {
      max-width: 100%;
      height: auto;
      border-radius: 0.75rem;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
      margin: 1.5rem 0;
    }

    /* Responsive */
    @media (max-width: 640px) {
      .article-content p {
        font-size: 1rem;
      }

      .article-content h2 {
        font-size: 1.4rem;
      }

      .article-content blockquote {
        padding: 1rem 1.5rem;
      }

      .article-content blockquote::before,
      .article-content blockquote::after {
        font-size: 2.5rem;
      }

      .article-content .float-left,
      .article-content .float-right {
        float: none;
        margin: 1rem auto;
        display: block;
        max-width: 100%;
      }
      
      .article-main-image {
        margin-left: -1rem;
        margin-right: -1rem;
        width: calc(100% + 2rem);
      }
      
      .article-main-image img {
        height: 12rem;
      }
    }

    /* Animation douce */
    .article-content blockquote {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .article-content blockquote:hover {
      transform: translateX(4px);
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }

    /* Impression */
    @media print {
      header, footer, .sticky, #shareBtn, #printBtn {
        display: none !important;
      }
      article {
        box-shadow: none;
        padding: 0;
      }
      .article-content blockquote {
        background: none;
        border-left: 2px solid #f97316;
        padding: 0.5rem 1rem;
        box-shadow: none;
      }
      .article-content blockquote::before,
      .article-content blockquote::after {
        display: none;
      }
      .article-main-image {
        margin: 0;
        width: 100%;
      }
    }
  </style>
</Layout>