---
import Layout from '../../layouts/Layout.astro';

// Définition des slugs pour chaque catégorie
const categoriesCulture = [
  {
    titre: "Danses traditionnelles",
    slug: "danses",
    icone: "💃",
    description: "Les danses qui rythment la vie du village",
    elements: [
      "Kang - Danse initiatique",
      "Dimassale - Danse des femmes",
      "Messoh - La plus belle parade",
      "Kougnag - Danse mystique"
    ]
  },
  {
    titre: "Notabilité",
    slug: "notabilite",
    icone: "👑",
    description: "L'organisation sociale traditionnelle",
    elements: [
      "Le chef (Fé)",
      "Le conseil des neuf notables )",
      "Le conseil des sept notables",
      "Les notables"
    ]
  },
  {
    titre: "Chapeaux traditionnels",
    slug: "chapeaux",
    icone: "🎩",
    description: "La symbolique des couvre-chefs",
    elements: [
      "Le mètang - Chapeau royal",
      "Le tchêu pfè - Chapeau des retraités",
      "Le tchêu phum- Chapeau des Tcheufé"
    ]
  },
  {
    titre: "Chaises et trônes",
    slug: "chaises",
    icone: "🪑",
    description: "Les sièges du pouvoir",
    elements: [
      "le Leng",
      "Le kouoh kouè"
    ]
  },
  {
    titre: "Cérémonies",
    slug: "ceremonies",
    icone: "🎉",
    description: "Les grands moments communautaires",
    elements: [
      "Le veuvage",
      "La purification",
      "La présentation des jumeaux",
      "Le mariage"
    ]
  },
  /*{
    titre: "Initiation",
    slug: "initiation",
    icone: "🔮",
    description: "Les passages vers la connaissance",
    elements: [
      "Initiation du Khe",
      "Société secrète du Ngi",
      "Initiation des femmes",
      "Apprentissage des traditions"
    ]
  }*/
];
---

<Layout title="Culture Bandenkop">
  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 bg-gradient-to-br from-orange-900 via-red-900 to-amber-900">
    <div class="absolute inset-0 opacity-10 bg-pattern"></div>
    <div class="relative container mx-auto px-6">
      <h1 class="text-5xl md:text-7xl font-black text-white text-center mb-6 animate-slide-up">
        Notre <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-yellow-300">Culture</span>
      </h1>
      <p class="text-xl text-orange-100 text-center max-w-3xl mx-auto">
        Plongez dans la richesse des traditions Bandenkop
      </p>
    </div>
  </section>

  <!-- Introduction -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-lg text-gray-600 leading-relaxed">
          La culture Bandenkop est un patrimoine vivant, transmis de génération en génération. 
          Elle se manifeste à travers les danses, les rites, l'organisation sociale et les croyances 
          qui donnent son identité unique à notre communauté.
        </p>
      </div>
    </div>
  </section>

  <!-- Grille culturelle -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {categoriesCulture.map((categorie) => (
          <a 
            href={`/culture/${categorie.slug}`}
            class="bg-white rounded-2xl shadow-lg p-6 hover:shadow-2xl transform hover:scale-105 transition-all duration-500 block"
          >
            <div class="text-5xl mb-4">{categorie.icone}</div>
            <h2 class="text-2xl font-bold text-gray-800 mb-3">{categorie.titre}</h2>
            <p class="text-gray-600 mb-4">{categorie.description}</p>
            <ul class="space-y-2 mb-4">
              {categorie.elements.map((element) => (
                <li class="flex items-start space-x-2">
                  <svg class="w-5 h-5 text-orange-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-600">{element}</span>
                </li>
              ))}
            </ul>
            <div class="inline-flex items-center text-orange-600 font-semibold group">
              En savoir plus
              <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Section spéciale : Le Khé et la divinité -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8">
        <a href="/culture/khe" class="bg-gradient-to-br from-orange-50 to-red-50 rounded-2xl p-8 hover:shadow-xl transition-all duration-300">
          <h2 class="text-3xl font-bold text-gray-800 mb-4 flex items-center">
            <span class="text-4xl mr-3">⚖️</span>
            Le Khé - La Vérité
          </h2>
          <p class="text-gray-600 leading-relaxed">
            Le Khé est l'épreuve de vérité, un jugement par lequel on prouve son innocence ou sa culpabilité. 
            Cette pratique ancestrale, encadrée par des rituels stricts, est considérée comme infaillible 
            car elle fait appel à la justice divine. Les ordalies, les serments et les épreuves traditionnelles 
            sont autant de manifestations du Khé dans la vie sociale.
          </p>
          <div class="mt-4 inline-flex items-center text-orange-600 font-semibold group">
            En savoir plus
            <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </div>
        </a>
        
        <a href="/culture/divinite" class="bg-gradient-to-br from-amber-50 to-orange-50 rounded-2xl p-8 hover:shadow-xl transition-all duration-300">
          <h2 class="text-3xl font-bold text-gray-800 mb-4 flex items-center">
            <span class="text-4xl mr-3">🙏</span>
            Sieh - La Divinité
          </h2>
          <p class="text-gray-600 leading-relaxed">
            Sieh est la force suprême, le créateur de toutes choses. Présent partout et en chacun, 
            il est honoré à travers les ancêtres qui servent d'intermédiaires entre le monde visible 
            et l'invisible. Les rites et sacrifices lui sont offerts pour maintenir l'harmonie entre 
            les vivants, les morts et les générations futures.
          </p>
          <div class="mt-4 inline-flex items-center text-orange-600 font-semibold group">
            En savoir plus
            <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Calendrier traditionnel -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-6">
      <h2 class="text-3xl font-bold text-center text-gray-800 mb-8">Les jours de la semaine</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
        <a href="/culture/semaines" class="bg-white rounded-xl p-4 text-center shadow-lg hover:shadow-xl transition-all duration-300">
          <span class="text-2xl block mb-2">🌞</span>
          <h3 class="font-bold">Liegang</h3>
          <p class="text-xs text-gray-600">Jour du marché</p>
        </a>
        <a href="/culture/semaines" class="bg-white rounded-xl p-4 text-center shadow-lg hover:shadow-xl transition-all duration-300">
          <span class="text-2xl block mb-2">🌅</span>
          <h3 class="font-bold">Djedjeu & Chepteh</h3>
          <p class="text-xs text-gray-600">Jours de repos</p>
        </a>
        <a href="/culture/semaines" class="bg-white rounded-xl p-4 text-center shadow-lg hover:shadow-xl transition-all duration-300">
          <span class="text-2xl block mb-2">🌄</span>
          <h3 class="font-bold">Liekouong</h3>
          <p class="text-xs text-gray-600">Jour de festivité</p>
        </a>
        <a href="/culture/semaines" class="bg-white rounded-xl p-4 text-center shadow-lg hover:shadow-xl transition-all duration-300">
          <span class="text-2xl block mb-2">🌙</span>
          <h3 class="font-bold">Temgou</h3>
          <p class="text-xs text-gray-600">Jour des sociétés secrètes</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Interdits et rites -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8">
        <div class="group cursor-default select-none" aria-disabled="true">
          <h2 class="text-2xl font-bold text-gray-800 mb-4 flex items-center">
            Les interdits (Tabous)
            <svg class="w-5 h-5 ml-2 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </h2>
          <ul class="space-y-3">
            <li class="flex items-start space-x-3">
              <span class="text-red-600 font-bold">•</span>
              <span>On ne porte pas son chapeau devant le chef</span>
            </li>
            <li class="flex items-start space-x-3">
              <span class="text-red-600 font-bold">•</span>
              <span>On ne tend pas la main à un aîné</span>
            </li>
            <li class="flex items-start space-x-3">
              <span class="text-red-600 font-bold">•</span>
              <span>Il est interdit de dépasser son père dans la notabilité</span>
            </li>
            <li class="flex items-start space-x-3">
              <span class="text-red-600 font-bold">•</span>
              <span>Il est interdit de détourner une succession</span>
            </li>
          </ul>
        </div>
        <div class="group cursor-default select-none" aria-disabled="true">
          <h2 class="text-2xl font-bold text-gray-800 mb-4 flex items-center">
            Les rites essentiels
            <svg class="w-5 h-5 ml-2 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </h2>
          <ul class="space-y-3">
            <li class="flex items-start space-x-3">
              <span class="text-orange-600 font-bold">•</span>
              <span>L'initiation à la danse kang</span>
            </li>
            <li class="flex items-start space-x-3">
              <span class="text-orange-600 font-bold">•</span>
              <span>Rites de mariage et dot</span>
            </li>
            <li class="flex items-start space-x-3">
              <span class="text-orange-600 font-bold">•</span>
              <span>Les rite veuvage</span>
            </li>
            <li class="flex items-start space-x-3">
              <span class="text-orange-600 font-bold">•</span>
              <span>Le rite de purification</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>