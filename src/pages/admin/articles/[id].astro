---
import Layout from '../../../layouts/Layout.astro';
const { id } = Astro.params;
---

<Layout title="Modifier l'article - Administration">
  <div class="min-h-screen bg-gradient-to-br from-orange-50 to-red-50 pt-24 pb-12">
    <div class="px-4 max-w-4xl mx-auto">
      
      <div class="flex items-center justify-between mb-8">
        <h1 class="font-['Playfair_Display'] text-3xl font-bold text-gray-800">
          Modifier l'article
        </h1>
        <a href="/admin/articles" class="text-orange-600 hover:text-orange-800">
          ← Retour
        </a>
      </div>
      
      <div class="bg-white rounded-2xl shadow-xl p-6" id="article-form-container">
        <!-- Loading -->
        <div id="loading" class="text-center py-8">
          <div class="inline-block animate-spin rounded-full h-8 w-8 border-4 border-orange-600 border-t-transparent"></div>
          <p class="mt-4 text-gray-600">Chargement de l'article...</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { getToken } from '../../../utils/auth';

    declare global {
      interface Window {
        supprimerArticle: () => Promise<void>;
      }
    }

    const API_URL = 'http://localhost:3001';
    const token = getToken();
    const articleId = window.location.pathname.split('/').pop();

    if (!token) {
      window.location.href = '/connexion';
    }

    async function chargerArticle() {
      try {
        const response = await fetch(`${API_URL}/api/articles/${articleId}`);
        const article = await response.json();
        
        const container = document.getElementById('article-form-container');
        if (!container) return;
        
        container.innerHTML = `
          <form id="editArticleForm" class="space-y-4">
            <input type="hidden" name="id" value="${article._id}">
            
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Titre *</label>
              <input type="text" name="titre" value="${article.titre}" required class="w-full px-4 py-2 border rounded-lg">
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Résumé *</label>
              <textarea name="resume" required rows="2" class="w-full px-4 py-2 border rounded-lg">${article.resume}</textarea>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Contenu *</label>
              <textarea name="contenu" required rows="6" class="w-full px-4 py-2 border rounded-lg">${article.contenu}</textarea>
            </div>
            
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Catégorie</label>
                <select name="categorie" class="w-full px-4 py-2 border rounded-lg">
                  <option value="Événement" ${article.categorie === 'Événement' ? 'selected' : ''}>Événement</option>
                  <option value="Tradition" ${article.categorie === 'Tradition' ? 'selected' : ''}>Tradition</option>
                  <option value="Développement" ${article.categorie === 'Développement' ? 'selected' : ''}>Développement</option>
                  <option value="Diaspora" ${article.categorie === 'Diaspora' ? 'selected' : ''}>Diaspora</option>
                  <option value="Politique" ${article.categorie === 'Politique' ? 'selected' : ''}>Politique</option>
                  <option value="Culture" ${article.categorie === 'Culture' ? 'selected' : ''}>Culture</option>
                </select>
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Auteur *</label>
                <input type="text" name="auteur" value="${article.auteur}" required class="w-full px-4 py-2 border rounded-lg">
              </div>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Image (URL)</label>
              <input type="url" name="image" value="${article.image}" class="w-full px-4 py-2 border rounded-lg">
            </div>
            
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Date de l'événement</label>
                <input type="date" name="dateEvenement" value="${article.dateEvenement ? article.dateEvenement.split('T')[0] : ''}" class="w-full px-4 py-2 border rounded-lg">
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Lieu</label>
                <input type="text" name="lieu" value="${article.lieu || ''}" class="w-full px-4 py-2 border rounded-lg">
              </div>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Tags (séparés par des virgules)</label>
              <input type="text" name="tags" value="${article.tags ? article.tags.join(', ') : ''}" class="w-full px-4 py-2 border rounded-lg">
            </div>
            
            <div class="flex items-center">
              <input type="checkbox" name="featured" id="featured" ${article.featured ? 'checked' : ''} class="w-4 h-4 text-orange-600">
              <label for="featured" class="ml-2 text-sm text-gray-700">Mettre en avant</label>
            </div>
            
            <div class="flex space-x-3 pt-4">
              <button type="submit" class="flex-1 bg-gradient-to-r from-orange-600 to-red-600 text-white py-3 rounded-lg font-semibold hover:shadow-lg">
                Mettre à jour
              </button>
              <button type="button" onclick="supprimerArticle()" class="flex-1 bg-red-500 text-white py-3 rounded-lg font-semibold hover:bg-red-600">
                Supprimer
              </button>
            </div>
          </form>
        `;
        
        const loading = document.getElementById('loading');
        if (loading) loading.style.display = 'none';
        
      } catch (error) {
        console.error('Erreur chargement:', error);
      }
    }

    window.supprimerArticle = async () => {
      if (!confirm('Êtes-vous sûr de vouloir supprimer définitivement cet article ?')) return;
      
      try {
        const response = await fetch(`${API_URL}/api/articles/${articleId}`, {
          method: 'DELETE',
          headers: { 'Authorization': `Bearer ${token}` }
        });
        
        if (response.ok) {
          alert('Article supprimé !');
          window.location.href = '/admin/articles';
        }
      } catch (error) {
        console.error('Erreur suppression:', error);
      }
    };

    document.addEventListener('submit', async (e) => {
      const target = e.target as HTMLFormElement | null;
      if (target?.id === 'editArticleForm') {
        e.preventDefault();
        
        const formData = new FormData(target);
        const baseArticle = Object.fromEntries(formData.entries()) as Record<string, FormDataEntryValue>;
        const article: Record<string, unknown> = { ...baseArticle };
        
        const rawTags = baseArticle.tags;
        if (typeof rawTags === 'string' && rawTags.trim()) {
          article.tags = rawTags
            .split(',')
            .map((tag: string) => tag.trim())
            .filter((tag: string) => Boolean(tag));
        }
        article.featured = formData.has('featured');
        
        try {
          const response = await fetch(`${API_URL}/api/articles/${articleId}`, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(article)
          });
          
          if (response.ok) {
            alert('Article mis à jour !');
            window.location.href = '/admin/articles';
          }
        } catch (error) {
          console.error('Erreur mise à jour:', error);
        }
      }
    });

    chargerArticle();
  </script>
</Layout>