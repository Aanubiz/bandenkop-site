---
import Layout from '../../layouts/Layout.astro';
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { getToken } from '../../utils/auth';
import { getApiUrl } from '../../config';

const API_URL = getApiUrl();
---

<Layout title="Dashboard Admin - Bandenkop">
  <AdminLayout>
    <div class="space-y-6">
      <!-- En-tête -->
      <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold text-gray-800">Tableau de bord</h1>
        <div class="text-sm text-gray-500" id="last-update">Chargement...</div>
      </div>

      <!-- Statistiques globales -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl shadow-lg p-6">
          <div class="flex items-center justify-between mb-4">
            <div class="p-3 bg-orange-100 rounded-lg">
              <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
              </svg>
            </div>
            <span class="text-3xl font-bold text-gray-800" id="stats-users">0</span>
          </div>
          <h3 class="text-gray-600 font-medium">Utilisateurs</h3>
          <p class="text-sm text-gray-400 mt-1" id="stats-users-detail">0 nouveaux ce mois</p>
        </div>

        <div class="bg-white rounded-xl shadow-lg p-6">
          <div class="flex items-center justify-between mb-4">
            <div class="p-3 bg-green-100 rounded-lg">
              <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
              </svg>
            </div>
            <span class="text-3xl font-bold text-gray-800" id="stats-questions">0</span>
          </div>
          <h3 class="text-gray-600 font-medium">Questions de quiz</h3>
          <p class="text-sm text-gray-400 mt-1" id="stats-questions-detail">0 par rubrique</p>
        </div>

        <div class="bg-white rounded-xl shadow-lg p-6">
          <div class="flex items-center justify-between mb-4">
            <div class="p-3 bg-blue-100 rounded-lg">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path>
              </svg>
            </div>
            <span class="text-3xl font-bold text-gray-800" id="stats-audio">0</span>
          </div>
          <h3 class="text-gray-600 font-medium">Mots audio</h3>
          <p class="text-sm text-gray-400 mt-1" id="stats-audio-detail">0 catégories</p>
        </div>

        <div class="bg-white rounded-xl shadow-lg p-6">
          <div class="flex items-center justify-between mb-4">
            <div class="p-3 bg-purple-100 rounded-lg">
              <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"></path>
              </svg>
            </div>
            <span class="text-3xl font-bold text-gray-800" id="stats-reponses">0</span>
          </div>
          <h3 class="text-gray-600 font-medium">Réponses</h3>
          <p class="text-sm text-gray-400 mt-1" id="stats-reponses-detail">aujourd'hui</p>
        </div>
      </div>

      <!-- Graphiques d'activité -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl shadow-lg p-6">
          <h2 class="text-lg font-bold text-gray-800 mb-4">Activité des 7 derniers jours</h2>
          <div class="h-64 flex items-end space-x-2" id="activity-chart">
            <!-- Rempli par JS -->
          </div>
        </div>

        <div class="bg-white rounded-xl shadow-lg p-6">
          <h2 class="text-lg font-bold text-gray-800 mb-4">Répartition par rubrique</h2>
          <div class="space-y-4" id="rubriques-stats">
            <!-- Rempli par JS -->
          </div>
        </div>
      </div>

      <!-- Actions rapides -->
      <div class="bg-white rounded-xl shadow-lg p-6">
        <h2 class="text-lg font-bold text-gray-800 mb-4">Actions rapides</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <a href="/admin/apprentissage/quiz" class="p-4 bg-orange-50 rounded-lg text-center hover:bg-orange-100 transition-colors">
            <span class="text-3xl block mb-2">📝</span>
            <span class="text-sm font-medium">Ajouter un quiz</span>
          </a>
          <a href="/admin/apprentissage/prononciation" class="p-4 bg-green-50 rounded-lg text-center hover:bg-green-100 transition-colors">
            <span class="text-3xl block mb-2">🎤</span>
            <span class="text-sm font-medium">Ajouter un mot</span>
          </a>
          <a href="/admin/apprentissage/categories" class="p-4 bg-blue-50 rounded-lg text-center hover:bg-blue-100 transition-colors">
            <span class="text-3xl block mb-2">📁</span>
            <span class="text-sm font-medium">Gérer catégories</span>
          </a>
          <a href="/admin/utilisateurs" class="p-4 bg-purple-50 rounded-lg text-center hover:bg-purple-100 transition-colors">
            <span class="text-3xl block mb-2">👥</span>
            <span class="text-sm font-medium">Utilisateurs</span>
          </a>
        </div>
      </div>
    </div>
  </AdminLayout>

  <script>
    import { getToken } from '../../utils/auth';
    import { getApiUrl } from '../../config';

    const API_URL = getApiUrl();
    const token = getToken();

    type ActiviteJour = {
      date: string;
      count: number;
    };

    type DashboardStats = {
      totalUsers: number;
      totalQuestions: number;
      totalAudio: number;
      reponsesAujourdhui: number;
      nouveauxUsersMois: number;
      totalCategories: number;
      questionsParRubrique: {
        quiz?: number;
        prononciation?: number;
      };
      activite7Jours?: ActiviteJour[];
      repartitionRubriques?: Record<string, number>;
    };

    const setText = (id: string, value: string | number) => {
      const el = document.getElementById(id);
      if (el) el.textContent = String(value);
    };

    async function loadStats() {
      try {
        const response = await fetch(`${API_URL}/api/admin/stats`, {
          headers: { Authorization: `Bearer ${token}` }
        });
        const stats = (await response.json()) as DashboardStats;

        // Mettre à jour les compteurs
        setText('stats-users', stats.totalUsers);
        setText('stats-questions', stats.totalQuestions);
        setText('stats-audio', stats.totalAudio);
        setText('stats-reponses', stats.reponsesAujourdhui);
        
        setText('stats-users-detail', `${stats.nouveauxUsersMois} nouveaux ce mois`);
        setText('stats-questions-detail', `${stats.questionsParRubrique?.quiz || 0} quiz, ${stats.questionsParRubrique?.prononciation || 0} audio`);
        setText('stats-audio-detail', `${stats.totalCategories} catégories`);
        setText('stats-reponses-detail', `${stats.reponsesAujourdhui} aujourd'hui`);
        
        setText('last-update', `Dernière mise à jour : ${new Date().toLocaleTimeString()}`);

        // Afficher le graphique d'activité
        if (stats.activite7Jours) {
          const chart = document.getElementById('activity-chart');
          if (!chart) return;
          const max = Math.max(...stats.activite7Jours.map((j: ActiviteJour) => j.count), 1);
          chart.innerHTML = stats.activite7Jours.map((jour: ActiviteJour) => `
            <div class="flex-1 flex flex-col items-center">
              <div class="w-full bg-orange-100 rounded-t-lg" style="height: ${(jour.count / max) * 180}px"></div>
              <span class="text-xs mt-2 text-gray-600">${jour.date}</span>
            </div>
          `).join('');
        }

        // Afficher les stats par rubrique
        const rubriques = document.getElementById('rubriques-stats');
        if (!rubriques) return;
        rubriques.innerHTML = Object.entries(stats.repartitionRubriques || {}).map(([rub, count]) => `
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-600">${rub}</span>
            <span class="text-sm font-semibold">${count}</span>
          </div>
        `).join('');

      } catch (error) {
        console.error('Erreur chargement stats:', error);
      }
    }

    document.addEventListener('DOMContentLoaded', loadStats);
  </script>
</Layout>