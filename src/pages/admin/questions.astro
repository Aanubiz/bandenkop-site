---
import Layout from '../../layouts/Layout.astro';
import { getApiUrl } from '../../config';

const API_URL = getApiUrl();
---

<Layout title="Admin - Gestion des questions">
  <section class="pt-24 pb-12">
    <div class="px-4 max-w-4xl mx-auto">
      <a href="/admin" class="inline-flex items-center gap-1 text-sm text-orange-600 hover:text-orange-800 mb-4 transition-colors">← Panneau admin</a>
      <h1 class="text-3xl font-bold mb-8">Gestion des questions</h1>
      
      <form id="questionForm" class="bg-white rounded-2xl shadow-xl p-6 space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Rubrique</label>
          <select name="rubrique" class="w-full p-3 border rounded-lg">
            <option value="quiz">Quiz</option>
            <option value="prononciation">Prononciation</option>
            <option value="association">Association</option>
          </select>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Niveau</label>
          <select name="niveau" class="w-full p-3 border rounded-lg">
            <option value="debutant">Débutant</option>
            <option value="intermediaire">Intermédiaire</option>
            <option value="avance">Avancé</option>
          </select>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Question (français)</label>
          <input type="text" name="questionFr" class="w-full p-3 border rounded-lg">
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Options (séparées par des virgules)</label>
          <input type="text" name="options" class="w-full p-3 border rounded-lg" placeholder="Option 1, Option 2, Option 3">
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Bonne réponse</label>
          <input type="text" name="reponse" class="w-full p-3 border rounded-lg">
        </div>
        
        <button type="submit" class="w-full bg-gradient-to-r from-orange-600 to-red-600 text-white py-3 rounded-xl font-semibold">
          Ajouter la question
        </button>
      </form>
      
      <div class="mt-8 bg-green-50 p-4 rounded-lg hidden" id="successMessage">
        ✅ Question ajoutée avec succès !
      </div>
    </div>
  </section>

  <script>
    const questionForm = document.getElementById('questionForm');
    if (questionForm) {
      questionForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const target = e.target as HTMLFormElement;
        const formData = new FormData(target);
        const optionsValue = formData.get('options');
        const options = optionsValue && typeof optionsValue === 'string' ? optionsValue.split(',').map((opt: string) => opt.trim()) : [];
        
        const question = {
          rubrique: formData.get('rubrique'),
          niveau: formData.get('niveau'),
          type: 'qcm',
          question: { fr: formData.get('questionFr') },
          options,
          reponse: formData.get('reponse'),
          points: 10,
          difficulte: 1
        };
        
        try {
          const response = await fetch('/api/questions', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(question)
          });
          
          if (response.ok) {
            const successMessage = document.getElementById('successMessage');
            if (successMessage) successMessage.classList.remove('hidden');
            target.reset();
            setTimeout(() => {
              if (successMessage) successMessage.classList.add('hidden');
            }, 3000);
          }
        } catch (error) {
          alert('Erreur lors de l\'ajout');
        }
      });
    }
  </script>
</Layout>