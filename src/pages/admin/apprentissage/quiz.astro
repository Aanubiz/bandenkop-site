---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Admin - Quiz">
    <div class="p-6 mt-24">
      <a href="/admin" class="inline-flex items-center gap-1 text-sm text-orange-600 hover:text-orange-800 mb-4 transition-colors">← Panneau admin</a>
      <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold">Gestion des questions de quiz</h1>
        <button onclick="openAddModal()" class="bg-orange-600 text-white px-4 py-2 rounded-lg hover:bg-orange-700">
          + Ajouter une question
        </button>
      </div>

      <!-- Filtres -->
      <div class="mb-4 flex gap-2">
        <input id="searchFilter" type="text" placeholder="Rechercher une question..." class="px-3 py-2 border rounded-lg min-w-[280px]" />
        <select id="niveauFilter" class="px-3 py-2 border rounded-lg">
          <option value="">Tous les niveaux</option>
          <option value="debutant">Débutant</option>
          <option value="intermediaire">Intermédiaire</option>
          <option value="avance">Avancé</option>
        </select>
        <select id="typeFilter" class="px-3 py-2 border rounded-lg">
          <option value="">Tous les types</option>
          <option value="qcm">QCM</option>
          <option value="vrai-faux">Vrai/Faux</option>
          <option value="texte">Texte</option>
        </select>
      </div>

      <!-- Modal d'ajout -->
      <div id="addModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
        <div class="bg-white rounded-xl p-6 max-w-2xl w-full max-h-[90vh] overflow-y-auto">
          <h2 class="text-xl font-bold mb-4">Ajouter une question</h2>
          
          <form id="quizForm" class="space-y-4">
            <div>
              <label class="block text-sm font-medium mb-1">Question (français) *</label>
              <input type="text" name="question.fr" required class="w-full px-3 py-2 border rounded-lg">
            </div>
            
            <div>
              <label class="block text-sm font-medium mb-1">Type *</label>
              <select name="type" id="questionType" required class="w-full px-3 py-2 border rounded-lg">
                <option value="qcm">QCM (choix multiples)</option>
                <option value="vrai-faux">Vrai / Faux</option>
                <option value="texte">Réponse écrite</option>
              </select>
            </div>

            <!-- Options (pour QCM) -->
            <div id="optionsContainer" class="space-y-2">
              <label class="block text-sm font-medium mb-1">Options *</label>
              <div class="flex gap-2">
                <input type="text" name="options[]" placeholder="Option 1" class="flex-1 px-3 py-2 border rounded-lg">
                <input type="radio" name="correctOption" value="0" class="w-4 h-4 mt-3"> Bonne réponse
              </div>
              <div class="flex gap-2">
                <input type="text" name="options[]" placeholder="Option 2" class="flex-1 px-3 py-2 border rounded-lg">
                <input type="radio" name="correctOption" value="1" class="w-4 h-4 mt-3"> Bonne réponse
              </div>
              <div class="flex gap-2">
                <input type="text" name="options[]" placeholder="Option 3" class="flex-1 px-3 py-2 border rounded-lg">
                <input type="radio" name="correctOption" value="2" class="w-4 h-4 mt-3"> Bonne réponse
              </div>
              <div class="flex gap-2">
                <input type="text" name="options[]" placeholder="Option 4" class="flex-1 px-3 py-2 border rounded-lg">
                <input type="radio" name="correctOption" value="3" class="w-4 h-4 mt-3"> Bonne réponse
              </div>
              <button type="button" onclick="addOption()" class="text-orange-600 text-sm">+ Ajouter une option</button>
            </div>

            <!-- Pour Vrai/Faux (caché par défaut) -->
            <div id="vfContainer" class="hidden space-y-2">
              <label class="block text-sm font-medium mb-1">Bonne réponse *</label>
              <div class="flex gap-4">
                <label class="flex items-center">
                  <input type="radio" name="vfCorrect" value="true" class="mr-2"> Vrai
                </label>
                <label class="flex items-center">
                  <input type="radio" name="vfCorrect" value="false" class="mr-2"> Faux
                </label>
              </div>
            </div>

            <!-- Pour réponse texte -->
            <div id="textContainer" class="hidden space-y-2">
              <label class="block text-sm font-medium mb-1">Réponse attendue *</label>
              <input type="text" name="reponseTexte" class="w-full px-3 py-2 border rounded-lg" placeholder="Ex: Bandenkop" />
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium mb-1">Niveau</label>
                <select name="niveau" class="w-full px-3 py-2 border rounded-lg">
                  <option value="debutant">Débutant</option>
                  <option value="intermediaire">Intermédiaire</option>
                  <option value="avance">Avancé</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium mb-1">Points</label>
                <input type="number" name="points" value="10" min="1" class="w-full px-3 py-2 border rounded-lg">
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium mb-1">Indices (optionnel, un par ligne)</label>
              <textarea name="indices" rows="2" class="w-full px-3 py-2 border rounded-lg"></textarea>
            </div>

            <div>
              <label class="block text-sm font-medium mb-1">Tags (séparés par des virgules)</label>
              <input type="text" name="tags" class="w-full px-3 py-2 border rounded-lg" placeholder="histoire, culture, tradition">
            </div>

            <div class="flex space-x-3 pt-4">
              <button type="submit" class="flex-1 bg-orange-600 text-white py-2 rounded-lg hover:bg-orange-700">
                Enregistrer
              </button>
              <button type="button" onclick="closeAddModal()" class="flex-1 bg-gray-200 py-2 rounded-lg hover:bg-gray-300">
                Annuler
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Liste des questions -->
      <div class="bg-white rounded-xl shadow-lg overflow-hidden">
        <table class="w-full">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">#</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Question</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Niveau</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Points</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
            </tr>
          </thead>
          <tbody id="quiz-list" class="divide-y divide-gray-200">
            <tr>
              <td colspan="6" class="px-6 py-4 text-center text-gray-500">Chargement...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

  <script>
    import { getToken } from '../../../utils/auth';

    declare global {
      interface Window {
        deleteItem: (id: string) => Promise<void>;
        editItem: (id: string) => void;
        openAddModal: () => void;
        closeAddModal: () => void;
        addOption: () => void;
      }
    }

    type QuizItem = {
      _id: string;
      type: string;
      niveau: 'debutant' | 'intermediaire' | 'avance';
      points: number;
      question: {
        fr: string;
        bandenkop?: string;
      };
    };

    type QuizPayload = {
      rubrique: 'quiz';
      type: string;
      question: { fr: string };
      niveau: string;
      points: number;
      tags: string[];
      indices?: string[];
      options?: string[];
      reponse?: string;
    };

    import { getApiUrl } from '../../../config';
    const API_URL = getApiUrl();
    const token = getToken();
    let quizCache: QuizItem[] = [];

    // Vérification du token
    if (!token) {
      window.location.href = '/connexion';
    }

    const getInput = (id: string) => document.getElementById(id) as HTMLInputElement | null;
    const getSelect = (id: string) => document.getElementById(id) as HTMLSelectElement | null;
    const getElement = (id: string) => document.getElementById(id) as HTMLElement | null;

    // ===== FONCTIONS GLOBALES (UNE SEULE FOIS) =====
    window.openAddModal = function() {
      console.log('🟢 openAddModal appelée');
      const modal = document.getElementById('addModal');
      if (modal) {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
      } else {
        console.error('❌ Modal non trouvé');
      }
    };

    window.closeAddModal = function() {
      console.log('🔴 closeAddModal appelée');
      const modal = document.getElementById('addModal');
      if (modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }
    };

    window.addOption = function() {
      console.log('➕ addOption appelée');
      const container = document.getElementById('optionsContainer');
      if (!container) return;
      
      const optionCount = container.querySelectorAll('.flex').length;
      const newOption = document.createElement('div');
      newOption.className = 'flex gap-2';
      newOption.innerHTML = `
        <input type="text" name="options[]" placeholder="Option ${optionCount + 1}" class="flex-1 px-3 py-2 border rounded-lg">
        <input type="radio" name="correctOption" value="${optionCount}" class="w-4 h-4 mt-3"> Bonne réponse
      `;
      container.insertBefore(newOption, container.lastElementChild);
    };

    window.deleteItem = async (id: string) => {
      if (!confirm('Supprimer cette question ?')) return;
      
      try {
        const response = await fetch(`${API_URL}/api/admin/quiz/${id}`, {
          method: 'DELETE',
          headers: { 'Authorization': `Bearer ${token}` }
        });
        
        if (response.ok) {
          loadQuiz();
        }
      } catch (error) {
        console.error('Erreur suppression:', error);
      }
    };

    window.editItem = (id: string) => {
      window.location.href = `/admin/apprentissage/quiz/${id}`;
    };

    function renderQuizList(data: QuizItem[]) {
      const tbody = document.getElementById('quiz-list');
      if (!tbody) return;

      const search = (getInput('searchFilter')?.value || '').toLowerCase().trim();
      const filtered = search
        ? data.filter((item) => {
            const text = `${item.question?.fr || ''} ${item.question?.bandenkop || ''} ${item.type || ''} ${item.niveau || ''}`.toLowerCase();
            return text.includes(search);
          })
        : data;

      if (filtered.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="6" class="px-6 py-8 text-center text-gray-500">
              Aucune question trouvée
            </td>
          </tr>
        `;
        return;
      }

      tbody.innerHTML = filtered.map((item: QuizItem, idx: number) => `
        <tr>
          <td class="px-6 py-4 text-gray-400 text-sm w-10">${idx + 1}</td>
          <td class="px-6 py-4">
            <div class="font-medium">${item.question.fr}</div>
            <div class="text-sm text-gray-500">${item.question.bandenkop || ''}</div>
          </td>
          <td class="px-6 py-4">
            <span class="px-2 py-1 bg-purple-100 text-purple-800 rounded-full text-xs">
              ${item.type}
            </span>
          </td>
          <td class="px-6 py-4">
            <span class="px-2 py-1 text-xs rounded-full ${
              item.niveau === 'debutant' ? 'bg-green-100 text-green-800' :
              item.niveau === 'intermediaire' ? 'bg-yellow-100 text-yellow-800' :
              'bg-red-100 text-red-800'
            }">${item.niveau}</span>
          </td>
          <td class="px-6 py-4">${item.points}</td>
          <td class="px-6 py-4 text-right space-x-2">
            <button onclick="editItem('${item._id}')" class="text-blue-600 hover:text-blue-800">✏️</button>
            <button onclick="deleteItem('${item._id}')" class="text-red-600 hover:text-red-800">🗑️</button>
          </td>
        </tr>
      `).join('');
    }

    async function loadQuiz() {
      try {
        console.log('📥 Chargement des questions...');
        
        const niveau = getSelect('niveauFilter')?.value ?? '';
        const type = getSelect('typeFilter')?.value ?? '';
        
        let url = `${API_URL}/api/admin/quiz`;
        const params = new URLSearchParams();
        if (niveau) params.append('niveau', niveau);
        if (type) params.append('type', type);
        if (params.toString()) url += '?' + params.toString();
        
        console.log('🔗 URL:', url);
        
        const response = await fetch(url, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        
        if (!response.ok) {
          throw new Error(`Erreur HTTP ${response.status}`);
        }
        
        const data = await response.json() as QuizItem[];
        quizCache = data;
        console.log('✅ Données reçues:', data);

        renderQuizList(quizCache);
      } catch (error) {
        console.error('❌ Erreur chargement:', error);
        const tbody = document.getElementById('quiz-list');
        const errorMessage = error instanceof Error ? error.message : 'Erreur inconnue';
        if (tbody) {
          tbody.innerHTML = `
            <tr>
              <td colspan="6" class="px-6 py-8 text-center text-red-600">
                ❌ Erreur de chargement: ${errorMessage}
              </td>
            </tr>
          `;
        }
      }
    }

    // Gestion du type de question
    const questionType = getSelect('questionType');
    questionType?.addEventListener('change', (e) => {
      const target = e.target as HTMLSelectElement | null;
      if (!target) return;
      const type = target.value;
      const optionsContainer = getElement('optionsContainer');
      const vfContainer = getElement('vfContainer');
      const textContainer = getElement('textContainer');
      if (optionsContainer) optionsContainer.style.display = type === 'qcm' ? 'block' : 'none';
      if (vfContainer) vfContainer.style.display = type === 'vrai-faux' ? 'block' : 'none';
      if (textContainer) textContainer.style.display = type === 'texte' ? 'block' : 'none';
    });

    const quizForm = document.getElementById('quizForm') as HTMLFormElement | null;
quizForm?.addEventListener('submit', async (e) => {
  e.preventDefault();
  
  console.log('📤 Tentative de création...');
  
  const form = e.currentTarget as HTMLFormElement | null;
  if (!form) return;

  const formData = new FormData(form);
  const typeValue = formData.get('type');
  const type = typeof typeValue === 'string' ? typeValue : 'qcm';
  const questionFr = formData.get('question.fr');
  const niveauValue = formData.get('niveau');
  const pointsValue = formData.get('points');
  const tagsValue = formData.get('tags');
  
  // Construire l'objet question
  const question: QuizPayload = {
    rubrique: 'quiz',
    type: type,
    question: {
      fr: typeof questionFr === 'string' ? questionFr : ''
    },
    niveau: typeof niveauValue === 'string' ? niveauValue : 'debutant',
    points: parseInt(typeof pointsValue === 'string' ? pointsValue : '10', 10),
    tags: typeof tagsValue === 'string'
      ? tagsValue.split(',').map((t: string) => t.trim()).filter((t: string) => Boolean(t))
      : []
  };

  console.log('📦 Question à envoyer:', question);

  // Gérer les indices
  const indicesValue = formData.get('indices');
  if (typeof indicesValue === 'string' && indicesValue.trim()) {
    question.indices = indicesValue.split('\n').filter((i: string) => i.trim().length > 0);
  }

  // Gérer les options selon le type
  if (type === 'qcm') {
    const options: string[] = [];
    const optionInputs = document.querySelectorAll('input[name="options[]"]') as NodeListOf<HTMLInputElement>;
    optionInputs.forEach((input: HTMLInputElement) => {
      if (input.value.trim()) options.push(input.value.trim());
    });
    question.options = options;
    
    const checked = document.querySelector('input[name="correctOption"]:checked') as HTMLInputElement | null;
    const correctIndexValue = checked?.value;
    const correctIndex = correctIndexValue !== undefined ? parseInt(correctIndexValue, 10) : -1;
    if (correctIndex !== undefined && options[correctIndex]) {
      question.reponse = options[correctIndex];
    }
    
    console.log('📋 Options QCM:', options);
    console.log('✅ Bonne réponse:', question.reponse);
  } else if (type === 'vrai-faux') {
    const vfInput = document.querySelector('input[name="vfCorrect"]:checked') as HTMLInputElement | null;
    const vfCorrect = vfInput?.value;
    if (vfCorrect !== undefined) {
      question.options = ['Vrai', 'Faux'];
      question.reponse = vfCorrect === 'true' ? 'Vrai' : 'Faux';
    }
    console.log('✅ Vrai/Faux:', question.reponse);
  } else if (type === 'texte') {
    const reponseTexte = formData.get('reponseTexte');
    if (typeof reponseTexte === 'string' && reponseTexte.trim()) {
      question.options = [];
      question.reponse = reponseTexte.trim();
    } else {
      alert('Veuillez renseigner la réponse attendue pour une question texte');
      return;
    }
  }

  try {
    console.log('📡 Envoi à:', `${API_URL}/api/admin/quiz`);
    
    const response = await fetch(`${API_URL}/api/admin/quiz`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${token}`
      },
      body: JSON.stringify(question)
    });
    
    console.log('📥 Statut réponse:', response.status);
    
    if (response.ok) {
      console.log('✅ Question créée avec succès');
      
      // Fermer le modal
      const modal = document.getElementById('addModal');
      if (modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }
      
      // Réinitialiser le formulaire
      form.reset();
      
      // Recharger la liste
      loadQuiz();
    } else {
      const errorData = await response.json();
      console.error('❌ Erreur API:', errorData);
      alert('Erreur: ' + (errorData.error || 'Erreur inconnue'));
    }
  } catch (error) {
    console.error('❌ Erreur réseau:', error);
    alert('Erreur de connexion au serveur');
  }
});

    // Filtres
    getSelect('niveauFilter')?.addEventListener('change', loadQuiz);
    getSelect('typeFilter')?.addEventListener('change', loadQuiz);
    getInput('searchFilter')?.addEventListener('input', () => renderQuizList(quizCache));

    // Chargement initial
    loadQuiz();
  </script>
</Layout>