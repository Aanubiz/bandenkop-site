---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Admin - Phonétique">
    <div class="p-6">
      <a href="/admin" class="inline-flex items-center gap-1 text-sm text-orange-600 hover:text-orange-800 mb-4 transition-colors">← Panneau admin</a>
      <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold">Sons phonétiques</h1>
        <button onclick="openAddModal()" class="bg-orange-600 text-white px-4 py-2 rounded-lg hover:bg-orange-700">
          + Ajouter un son
        </button>
      </div>

      <div class="mb-4">
        <input id="searchFilter" type="text" placeholder="Rechercher un son, exemple, niveau..." class="w-full md:w-[420px] px-3 py-2 border rounded-lg" />
      </div>

      <!-- Modal d'ajout -->
      <div id="addModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
        <div class="bg-white rounded-xl p-6 max-w-2xl w-full max-h-[90vh] overflow-y-auto">
          <h2 class="text-xl font-bold mb-4">Ajouter un son phonétique</h2>
          
          <form id="phonetiqueForm" class="space-y-4">
            <div>
              <label class="block text-sm font-medium mb-1">Symbole phonétique *</label>
              <input type="text" name="son" required class="w-full px-3 py-2 border rounded-lg" placeholder="Ex: ŋ, ɲ, ⁿd">
            </div>

            <div>
              <label class="block text-sm font-medium mb-1">Exemple de mot *</label>
              <input type="text" name="exempleMot" required class="w-full px-3 py-2 border rounded-lg" placeholder="Ex: ngang">
            </div>

            <div>
              <label class="block text-sm font-medium mb-1">Fichier audio (prononciation du son) *</label>
              <input type="file" id="sonAudio" accept="audio/*" required class="w-full">
            </div>

            <div>
              <label class="block text-sm font-medium mb-1">Description / conseil de prononciation</label>
              <textarea name="description" rows="2" class="w-full px-3 py-2 border rounded-lg"
                placeholder="Ex: Son comme dans 'camping' en français"></textarea>
            </div>

            <div>
              <label class="block text-sm font-medium mb-1">Image position bouche (optionnel)</label>
              <input type="file" id="boucheImage" accept="image/*" class="w-full">
            </div>

            <div>
              <label class="block text-sm font-medium mb-2">Mots pour pratique</label>
              <div id="motsPratique">
                <div class="flex gap-2 mb-2">
                  <input type="text" name="motPratique[]" placeholder="Mot" class="flex-1 px-3 py-2 border rounded-lg">
                  <input type="file" name="audioPratique[]" accept="audio/*" class="flex-1">
                </div>
              </div>
              <button type="button" onclick="addMotPratique()" class="text-orange-600 text-sm">+ Ajouter un mot</button>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium mb-1">Niveau</label>
                <select name="niveau" class="w-full px-3 py-2 border rounded-lg">
                  <option value="debutant">Débutant</option>
                  <option value="intermediaire">Intermédiaire</option>
                  <option value="avance">Avancé</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium mb-1">Points</label>
                <input type="number" name="points" value="8" min="1" class="w-full px-3 py-2 border rounded-lg">
              </div>
            </div>

            <div class="flex space-x-3 pt-4">
              <button type="submit" class="flex-1 bg-orange-600 text-white py-2 rounded-lg hover:bg-orange-700">
                Enregistrer
              </button>
              <button type="button" onclick="closeAddModal()" class="flex-1 bg-gray-200 py-2 rounded-lg hover:bg-gray-300">
                Annuler
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Liste des sons -->
      <div class="bg-white rounded-xl shadow-lg overflow-hidden">
        <table class="w-full">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">#</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Son</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Exemple</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Audio</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Niveau</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
            </tr>
          </thead>
          <tbody id="phonetique-list" class="divide-y divide-gray-200">
            <tr>
              <td colspan="6" class="px-6 py-4 text-center text-gray-500">Chargement...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

  <script>
    import { getToken } from '../../../utils/auth';

    declare global {
      interface Window {
        addMotPratique: () => void;
        playAudio: (url: string) => void;
        deleteItem: (id: string) => Promise<void>;
        editItem: (id: string) => void;
        openAddModal: () => void;
        closeAddModal: () => void;
      }
    }

    type PhonetiqueItem = {
      _id: string;
      son: string;
      exempleMot: string;
      exempleAudio: string;
      niveau: 'debutant' | 'intermediaire' | 'avance';
    };

    import { getApiUrl } from '../../../config';
    const API_URL = getApiUrl();
    const token = getToken();
    let phonetiqueCache: PhonetiqueItem[] = [];

    if (!token) window.location.href = '/connexion';

    const getElement = (id: string) => document.getElementById(id) as HTMLElement | null;

    function renderPhonetique(items: PhonetiqueItem[]) {
      const tbody = document.getElementById('phonetique-list');
      if (!tbody) return;

      const search = (document.getElementById('searchFilter') as HTMLInputElement | null)?.value.toLowerCase().trim() || '';
      const filtered = search
        ? items.filter((item) => {
            const txt = `${item.son} ${item.exempleMot} ${item.niveau}`.toLowerCase();
            return txt.includes(search);
          })
        : items;

      if (!filtered.length) {
        tbody.innerHTML = `
          <tr>
            <td colspan="6" class="px-6 py-4 text-center text-gray-500">Aucun son trouvé</td>
          </tr>
        `;
        return;
      }

      tbody.innerHTML = filtered.map((item: PhonetiqueItem, idx: number) => `
        <tr>
          <td class="px-6 py-4 text-gray-400 text-sm w-10">${idx + 1}</td>
          <td class="px-6 py-4">
            <span class="font-mono text-lg font-bold">${item.son}</span>
          </td>
          <td class="px-6 py-4">
            ${item.exempleMot}
          </td>
          <td class="px-6 py-4">
            <button onclick="playAudio('${item.exempleAudio}')" class="text-orange-600 hover:text-orange-800">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </button>
          </td>
          <td class="px-6 py-4">
            <span class="px-2 py-1 text-xs rounded-full ${
              item.niveau === 'debutant' ? 'bg-green-100 text-green-800' :
              item.niveau === 'intermediaire' ? 'bg-yellow-100 text-yellow-800' :
              'bg-red-100 text-red-800'
            }">${item.niveau}</span>
          </td>
          <td class="px-6 py-4 text-right space-x-2">
            <button onclick="editItem('${item._id}')" class="text-blue-600 hover:text-blue-800">✏️</button>
            <button onclick="deleteItem('${item._id}')" class="text-red-600 hover:text-red-800">🗑️</button>
          </td>
        </tr>
      `).join('');
    }

    window.addMotPratique = () => {
      const container = getElement('motsPratique');
      if (!container) return;
      const div = document.createElement('div');
      div.className = 'flex gap-2 mb-2';
      div.innerHTML = `
        <input type="text" name="motPratique[]" placeholder="Mot" class="flex-1 px-3 py-2 border rounded-lg">
        <input type="file" name="audioPratique[]" accept="audio/*" class="flex-1">
      `;
      container.appendChild(div);
    };

    async function loadPhonetique() {
      try {
        const response = await fetch(`${API_URL}/api/admin/phonetique`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await response.json() as PhonetiqueItem[];
        phonetiqueCache = Array.isArray(data) ? data : [];
        renderPhonetique(phonetiqueCache);
      } catch (error) {
        console.error('Erreur chargement:', error);
      }
    }

    window.playAudio = (url: string) => {
      const audio = new Audio(url);
      audio.play();
    };

    window.deleteItem = async (id: string) => {
      if (!confirm('Supprimer ce son ?')) return;
      
      try {
        await fetch(`${API_URL}/api/admin/phonetique/${id}`, {
          method: 'DELETE',
          headers: { 'Authorization': `Bearer ${token}` }
        });
        loadPhonetique();
      } catch (error) {
        console.error('Erreur suppression:', error);
      }
    };

    window.editItem = (id: string) => {
      window.location.href = `/admin/apprentissage/phonetique/${id}`;
    };

    window.openAddModal = () => {
      const addModal = getElement('addModal');
      if (!addModal) return;
      addModal.classList.remove('hidden');
      addModal.classList.add('flex');
    };

    window.closeAddModal = () => {
      const addModal = getElement('addModal');
      if (!addModal) return;
      addModal.classList.add('hidden');
      addModal.classList.remove('flex');
    };

    document.getElementById('searchFilter')?.addEventListener('input', () => renderPhonetique(phonetiqueCache));
    loadPhonetique();
  </script>
</Layout>