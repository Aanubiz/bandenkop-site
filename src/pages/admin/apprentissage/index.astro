---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Administration - Apprentissage">
    <div class="p-6">
      <h1 class="text-2xl font-bold mb-6">Gestion de l'apprentissage</h1>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Carte Quiz -->
        <a href="/admin/apprentissage/quiz" class="bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition-all group">
          <div class="text-4xl mb-4">📝</div>
          <h2 class="text-xl font-bold mb-2">Questions de Quiz</h2>
          <p class="text-gray-600 mb-4">Gérer les questions à choix multiples</p>
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-500" id="quiz-count">Chargement...</span>
            <span class="text-orange-600 group-hover:translate-x-2 transition-transform">→</span>
          </div>
        </a>

        <!-- Carte Prononciation -->
        <a href="/admin/apprentissage/prononciation" class="bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition-all group">
          <div class="text-4xl mb-4">🎤</div>
          <h2 class="text-xl font-bold mb-2">Prononciation</h2>
          <p class="text-gray-600 mb-4">Mots avec fichiers audio</p>
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-500" id="prononciation-count">Chargement...</span>
            <span class="text-orange-600 group-hover:translate-x-2 transition-transform">→</span>
          </div>
        </a>

        <!-- Carte Écriture -->
        <a href="/admin/apprentissage/ecriture" class="bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition-all group">
          <div class="text-4xl mb-4">✍️</div>
          <h2 class="text-xl font-bold mb-2">Exercices d'écriture</h2>
          <p class="text-gray-600 mb-4">Phrases à trous, traductions</p>
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-500" id="ecriture-count">Chargement...</span>
            <span class="text-orange-600 group-hover:translate-x-2 transition-transform">→</span>
          </div>
        </a>

        <!-- Carte Phonétique -->
        <a href="/admin/apprentissage/phonetique" class="bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition-all group">
          <div class="text-4xl mb-4">🔊</div>
          <h2 class="text-xl font-bold mb-2">Sons phonétiques</h2>
          <p class="text-gray-600 mb-4">[ŋ], [ɲ], [ⁿd] et autres</p>
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-500" id="phonetique-count">Chargement...</span>
            <span class="text-orange-600 group-hover:translate-x-2 transition-transform">→</span>
          </div>
        </a>

        <!-- Carte Association -->
        <a href="/admin/apprentissage/association" class="bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition-all group">
          <div class="text-4xl mb-4">🎯</div>
          <h2 class="text-xl font-bold mb-2">Association mot-image</h2>
          <p class="text-gray-600 mb-4">Paires mot + image</p>
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-500" id="association-count">Chargement...</span>
            <span class="text-orange-600 group-hover:translate-x-2 transition-transform">→</span>
          </div>
        </a>

        <!-- Carte Import en masse -->
        <a href="/admin/apprentissage/import" class="bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition-all group border-2 border-dashed border-orange-300">
          <div class="text-4xl mb-4">📦</div>
          <h2 class="text-xl font-bold mb-2">Import en masse</h2>
          <p class="text-gray-600 mb-4">Ajouter plusieurs éléments par fichier CSV</p>
          <span class="text-orange-600 group-hover:translate-x-2 transition-transform block text-right">→</span>
        </a>
      </div>
    </div>

  <script>
    async function loadCounts() {
      const endpoints = [
        { id: 'quiz-count', url: '/api/admin/quiz/count' },
        { id: 'prononciation-count', url: '/api/admin/prononciation/count' },
        { id: 'ecriture-count', url: '/api/admin/ecriture/count' },
        { id: 'phonetique-count', url: '/api/admin/phonetique/count' },
        { id: 'association-count', url: '/api/admin/association/count' }
      ];

      for (const endpoint of endpoints) {
        try {
          const response = await fetch(endpoint.url);
          const data = await response.json();
          const el = document.getElementById(endpoint.id);
          if (el) el.textContent = data.count + ' éléments';
        } catch (error) {
          const el = document.getElementById(endpoint.id);
          if (el) el.textContent = 'Erreur';
        }
      }
    }

    loadCounts();
  </script>
</Layout>