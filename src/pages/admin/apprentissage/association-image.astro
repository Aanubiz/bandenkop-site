---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Admin - Association icône FR/BK">
  <div class="p-6 mt-24 space-y-6">
    <a href="/admin" class="inline-flex items-center gap-1 text-sm text-orange-600 hover:text-orange-800 transition-colors">← Panneau admin</a>
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-bold">Association icône Français ↔ Bandenkop</h1>
      <button id="open-add" class="bg-orange-600 text-white px-4 py-2 rounded-lg hover:bg-orange-700">+ Ajouter</button>
    </div>

    <div>
      <input id="searchFilter" type="text" placeholder="Rechercher français, bandenkop, catégorie, niveau..." class="w-full md:w-[420px] px-3 py-2 border rounded-lg" />
    </div>

    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">#</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Français</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Icône</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Bandenkop</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Niveau</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody id="list" class="divide-y divide-gray-200">
          <tr><td colspan="6" class="px-6 py-8 text-center text-gray-500">Chargement...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div id="modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50 p-4">
    <div class="bg-white rounded-xl p-6 w-full max-w-2xl max-h-[90vh] overflow-y-auto">
      <h2 id="modal-title" class="text-xl font-bold mb-4">Ajouter une association icône</h2>
      <form id="form" class="space-y-4">
        <input type="hidden" name="id" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div>
            <label class="text-sm font-medium">Mot français *</label>
            <input name="motFrancais" required class="w-full px-3 py-2 border rounded-lg" />
          </div>
          <div>
            <label class="text-sm font-medium">Mot Bandenkop *</label>
            <input name="motBandenkop" required class="w-full px-3 py-2 border rounded-lg" />
          </div>
        </div>

        <div>
          <label class="text-sm font-medium">Lien icône (URL) - optionnel</label>
          <input name="iconUrl" placeholder="https://.../icon.svg" class="w-full px-3 py-2 border rounded-lg" />
        </div>

        <div>
          <label class="text-sm font-medium">Code SVG - optionnel</label>
          <textarea name="iconSvg" rows="4" placeholder="<svg ...>...</svg>" class="w-full px-3 py-2 border rounded-lg"></textarea>
          <p class="text-xs text-gray-500 mt-1">Ajoute soit un lien, soit un SVG (au moins un des deux).</p>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-sm font-medium">Catégorie</label>
            <select name="categorie" class="w-full px-3 py-2 border rounded-lg">
              <option value="objet">Objet</option>
              <option value="animal">Animal</option>
              <option value="personne">Personne</option>
              <option value="action">Action</option>
              <option value="nature">Nature</option>
            </select>
          </div>
          <div>
            <label class="text-sm font-medium">Niveau</label>
            <select name="niveau" class="w-full px-3 py-2 border rounded-lg">
              <option value="debutant">Débutant</option>
              <option value="intermediaire">Intermédiaire</option>
              <option value="avance">Avancé</option>
            </select>
          </div>
        </div>

        <div class="flex gap-3 pt-2">
          <button class="flex-1 bg-orange-600 text-white py-2 rounded-lg hover:bg-orange-700" type="submit">Enregistrer</button>
          <button id="close-modal" class="flex-1 bg-gray-200 py-2 rounded-lg hover:bg-gray-300" type="button">Annuler</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import { initAdminAssociationImagePage } from '../../../scripts/admin-association-image';

    document.addEventListener('DOMContentLoaded', initAdminAssociationImagePage);
  </script>
</Layout>
