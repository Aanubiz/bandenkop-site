---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Admin - Association">
    <div class="p-6">
      <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold">Association mot-image</h1>
        <button onclick="openAddModal()" class="bg-orange-600 text-white px-4 py-2 rounded-lg hover:bg-orange-700">
          + Ajouter une paire
        </button>
      </div>

      <!-- Modal d'ajout -->
      <div id="addModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
        <div class="bg-white rounded-xl p-6 max-w-2xl w-full max-h-[90vh] overflow-y-auto">
          <h2 class="text-xl font-bold mb-4">Ajouter une association mot-image</h2>
          
          <form id="associationForm" class="space-y-4">
            <div>
              <label class="block text-sm font-medium mb-1">Mot en Bandenkop *</label>
              <input type="text" name="motBandenkop" required class="w-full px-3 py-2 border rounded-lg">
            </div>

            <div>
              <label class="block text-sm font-medium mb-1">Mot en français *</label>
              <input type="text" name="motFrancais" required class="w-full px-3 py-2 border rounded-lg">
            </div>

            <div>
              <label class="block text-sm font-medium mb-1">Image *</label>
              <input type="file" id="imageFile" accept="image/*" required class="w-full">
            </div>

            <div>
              <label class="block text-sm font-medium mb-1">Audio (prononciation) - optionnel</label>
              <input type="file" id="audioFile" accept="audio/*" class="w-full">
            </div>

            <div>
              <label class="block text-sm font-medium mb-1">Catégorie</label>
              <select name="categorie" class="w-full px-3 py-2 border rounded-lg">
                <option value="objet">Objet</option>
                <option value="animal">Animal</option>
                <option value="personne">Personne</option>
                <option value="action">Action</option>
                <option value="nature">Nature</option>
              </select>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium mb-1">Niveau</label>
                <select name="niveau" class="w-full px-3 py-2 border rounded-lg">
                  <option value="debutant">Débutant</option>
                  <option value="intermediaire">Intermédiaire</option>
                  <option value="avance">Avancé</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium mb-1">Points</label>
                <input type="number" name="points" value="10" min="1" class="w-full px-3 py-2 border rounded-lg">
              </div>
            </div>

            <div class="flex space-x-3 pt-4">
              <button type="submit" class="flex-1 bg-orange-600 text-white py-2 rounded-lg hover:bg-orange-700">
                Enregistrer
              </button>
              <button type="button" onclick="closeAddModal()" class="flex-1 bg-gray-200 py-2 rounded-lg hover:bg-gray-300">
                Annuler
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Liste des associations -->
      <div class="bg-white rounded-xl shadow-lg overflow-hidden">
        <table class="w-full">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Mot</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Image</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Catégorie</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Niveau</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
            </tr>
          </thead>
          <tbody id="association-list" class="divide-y divide-gray-200">
            <tr>
              <td colspan="5" class="px-6 py-4 text-center text-gray-500">Chargement...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

  <script>
    import { getToken } from '../../../utils/auth';

    declare global {
      interface Window {
        deleteItem: (id: string) => Promise<void>;
        editItem: (id: string) => void;
        openAddModal: () => void;
        closeAddModal: () => void;
      }
    }

    type AssociationItem = {
      _id: string;
      motBandenkop: string;
      motFrancais: string;
      imageUrl: string;
      categorie: string;
      niveau: 'debutant' | 'intermediaire' | 'avance';
    };

    const API_URL = 'http://localhost:3001';
    const token = getToken();

    if (!token) window.location.href = '/connexion';

    const getElement = (id: string) => document.getElementById(id) as HTMLElement | null;

    async function loadAssociation() {
      try {
        const response = await fetch(`${API_URL}/api/admin/association`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await response.json() as AssociationItem[];
        
        const tbody = document.getElementById('association-list');
        if (!tbody) return;

        tbody.innerHTML = data.map((item: AssociationItem) => `
          <tr>
            <td class="px-6 py-4">
              <div class="font-medium">${item.motBandenkop}</div>
              <div class="text-sm text-gray-500">${item.motFrancais}</div>
            </td>
            <td class="px-6 py-4">
              <img src="${item.imageUrl}" alt="${item.motBandenkop}" class="w-12 h-12 object-cover rounded">
            </td>
            <td class="px-6 py-4">
              <span class="px-2 py-1 bg-blue-100 text-blue-800 rounded-full text-xs">
                ${item.categorie}
              </span>
            </td>
            <td class="px-6 py-4">
              <span class="px-2 py-1 text-xs rounded-full ${
                item.niveau === 'debutant' ? 'bg-green-100 text-green-800' :
                item.niveau === 'intermediaire' ? 'bg-yellow-100 text-yellow-800' :
                'bg-red-100 text-red-800'
              }">${item.niveau}</span>
            </td>
            <td class="px-6 py-4 text-right space-x-2">
              <button onclick="editItem('${item._id}')" class="text-blue-600 hover:text-blue-800">✏️</button>
              <button onclick="deleteItem('${item._id}')" class="text-red-600 hover:text-red-800">🗑️</button>
            </td>
          </tr>
        `).join('');
      } catch (error) {
        console.error('Erreur chargement:', error);
      }
    }

    window.deleteItem = async (id: string) => {
      if (!confirm('Supprimer cette association ?')) return;
      
      try {
        await fetch(`${API_URL}/api/admin/association/${id}`, {
          method: 'DELETE',
          headers: { 'Authorization': `Bearer ${token}` }
        });
        loadAssociation();
      } catch (error) {
        console.error('Erreur suppression:', error);
      }
    };

    window.editItem = (id: string) => {
      window.location.href = `/admin/apprentissage/association/${id}`;
    };

    window.openAddModal = () => {
      const addModal = getElement('addModal');
      if (!addModal) return;
      addModal.classList.remove('hidden');
      addModal.classList.add('flex');
    };

    window.closeAddModal = () => {
      const addModal = getElement('addModal');
      if (!addModal) return;
      addModal.classList.add('hidden');
      addModal.classList.remove('flex');
    };

    loadAssociation();
  </script>
</Layout>