---
// src/components/HistoireSection.astro
const chapitresHistoire = [
  {
    periode: "Origines ",
    titre: "La Naissance de Bandenkop",
    description: "Découvrez les origines mystiques et historiques de notre village, fondé par un chasseur nomade",
    image: "/images/histoire/first_king.jpg",
    icone: "🌄",
    lien: "/histoire#origines",
    details: [
      "Migration des premiers habitants",
      "Installation sur les terres actuelles",
      "Fondation du village par le premier chef",
      "Signification du nom 'Bandenkop'"
    ]
  },
  {
    periode: "Formation ",
    titre: "L'Âge d'Or du Village",
    description: "La structuration sociale et politique, l'établissement de la chefferies et des notabilités.",
    image: "/images/histoire/formation.jpg",
    icone: "🏛️",
    lien: "/histoire#formation",
    details: [
      "Création des premières institutions",
      "Mise en place du système de notabilité",
      "Développement des alliances "
    ]
  },
  {
    periode: "Alliances ",
    titre: "Les Grandes Alliances",
    description: "Les pactes d'amitié et de fraternité avec les villages voisins qui façonnent encore aujourd'hui nos relations.",
    image: "/images/histoire/alliances.jpeg",
    icone: "🤝",
    lien: "/histoire#alliances",
    details: [
      "Alliance avec Babouantou",
      "Lien de fraternité avec Bapa",
      "Établissement des routes commerciales"
    ]
  },
  {
    periode: "Batailles ",
    titre: "Les Guerres d'expansion et de Défense",
    description: "Les grandes batailles menées pour protéger le territoire et l'indépendance du village.",
    image: "/images/histoire/batailles.jpg",
    icone: "⚔️",
    lien: "/histoire#batailles",
    details: [
      "Guerre contre les Bangou",
      "Défense contre les envahisseurs Bandjoun",
      "Guerre contre les ",
      "Héros tombés au combat"
    ]
  },
  {
    periode: "Résistance ",
    titre: "La Résistance Anticoloniale",
    description: "L'opposition farouche à la pénétration coloniale française.",
    image: "/images/histoire/resistance.jpeg",
    icone: "✊",
    lien: "/histoire#resistance",
    details: [
      "La fameuse guerre dite du maquis",
      "Le quertier général de l'Armee de libération",
      "Cachette dans les forêts",
      "Le rôle des chefs dans la résistance"
    ]
  },
  {
    periode: "Exil ",
    titre: "L'Exil Vers Bangou",
    description: "La période sombre où une partie du peuple dut se réfugier chez nos voisins de Bangou.",
    image: "/images/histoire/exil.jpg",
    icone: "🚶",
    lien: "/histoire#exil",
    details: [
      "Les raisons de l'exil forcé",
      "La vie en terre d'accueil",
      "La préservation des traditions en exil"
    ]
  },
  {
    periode: "Retour ",
    titre: "Le Retour Triomphal",
    description: "Le retour au village et la reconstruction de la communauté après des années d'absence.",
    image: "/images/histoire/retour.jpg",
    icone: "🏡",
    lien: "/histoire#retour",
    details: [
      "Les négociations pour le retour",
      "La réinstallation sur les terres ancestrales",
      "La renaissance des institutions"
    ]
  },
  {
    periode: "Reconstruction",
    titre: "La Renaissance",
    description: "La reconstruction du village et le développement moderne tout en préservant l'héritage culturel.",
    image: "/images/histoire/reconstruction.jpg",
    icone: "🏗️",
    lien: "/histoire#reconstruction",
    details: [
      "Construction des infrastructures modernes",
      "Création des écoles et centres de santé",
      "Établissement des relations avec la diaspora"
    ]
  },
  {
    periode: "Perspectives ",
    titre: "Vers l'Avenir",
    description: "Les projets de développement et la vision pour les générations futures.",
    image: "/images/histoire/perspectives.jpg",
    icone: "🚀",
    lien: "/histoire#perspectives",
    details: [
      "Projets de développement durable",
      "Préservation du patrimoine culturel"
    ]
  }
];
---

<section class="py-8 sm:py-12 md:py-16 lg:py-20 bg-gradient-to-b from-white to-orange-50">
  <div class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
    <div class="text-center mb-6 sm:mb-8 md:mb-10 lg:mb-12">
      <h2 class="font-['Playfair_Display'] text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-black mb-3 sm:mb-4">
        Notre <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-600 to-red-600">Histoire</span>
      </h2>
      <p class="text-sm sm:text-base md:text-lg text-gray-600 max-w-3xl mx-auto px-4">
        Un voyage à travers les âges, un héritage culturel a nul autre pareille
      </p>
    </div>

    <!-- Timeline interactive -->
    <div class="relative">
      <!-- Ligne de temps centrale (cachée sur mobile) -->
      <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-orange-300 via-red-300 to-orange-300 hidden lg:block"></div>

      <div class="space-y-6 sm:space-y-8 md:space-y-10 lg:space-y-12">
        {chapitresHistoire.map((chapitre, index) => (
          <div class={`relative flex flex-col lg:flex-row ${index % 2 === 0 ? '' : 'lg:flex-row-reverse'} items-center gap-4 sm:gap-6 md:gap-8`}>
            <!-- Point sur la timeline -->
            <div class="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 sm:w-5 sm:h-5 md:w-6 md:h-6 bg-orange-600 rounded-full border-4 border-white hidden lg:block"></div>
            
            <!-- Contenu -->
            <div class={`w-full lg:w-1/2 ${index % 2 === 0 ? 'lg:pr-8 xl:pr-12' : 'lg:pl-8 xl:pl-12'}`}>
              <div class="bg-white rounded-xl sm:rounded-2xl shadow-lg hover:shadow-2xl transform hover:scale-[1.02] transition-all duration-500 group">
                <div class="relative h-40 sm:h-48 md:h-56 overflow-hidden rounded-t-xl sm:rounded-t-2xl">
                  <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent z-10"></div>
                  <img src={chapitre.image} alt={chapitre.titre} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                  <div class="absolute top-2 sm:top-3 md:top-4 left-2 sm:left-3 md:left-4 text-2xl sm:text-3xl md:text-4xl z-20">{chapitre.icone}</div>
                  <div class="absolute bottom-2 sm:bottom-3 md:bottom-4 left-2 sm:left-3 md:left-4 z-20">
                    <span class="bg-orange-600 text-white px-2 sm:px-3 py-0.5 sm:py-1 rounded-full text-[10px] sm:text-xs md:text-sm font-semibold">
                      {chapitre.periode}
                    </span>
                  </div>
                </div>
                <div class="p-4 sm:p-5 md:p-6">
                  <h3 class="text-base sm:text-lg md:text-xl lg:text-2xl font-bold text-gray-800 mb-2 sm:mb-3">{chapitre.titre}</h3>
                  <p class="text-xs sm:text-sm md:text-base text-gray-600 mb-3 sm:mb-4">{chapitre.description}</p>
                  <ul class="space-y-1 sm:space-y-2 mb-3 sm:mb-4">
                    {chapitre.details.slice(0, 2).map((detail) => (
                      <li class="flex items-start space-x-1 sm:space-x-2">
                        <svg class="w-3 h-3 sm:w-4 sm:h-4 text-orange-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span class="text-xs sm:text-sm text-gray-600">{detail}</span>
                      </li>
                    ))}
                    <li class="text-xs sm:text-sm text-gray-500 italic">...</li>
                  </ul>
                  <a 
                    href={chapitre.lien}
                    class="inline-flex items-center text-orange-600 font-semibold hover:text-orange-800 transition-colors text-xs sm:text-sm md:text-base"
                  >
                    Lire la suite
                    <svg class="w-3 h-3 sm:w-4 sm:h-4 ml-1 sm:ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
            
            <!-- Espace vide pour l'alternance -->
            <div class="hidden lg:block lg:w-1/2"></div>
          </div>
        ))}
      </div>
    </div>

    <!-- Version mobile simplifiée -->
    <div class="lg:hidden mt-6 sm:mt-8 space-y-3 sm:space-y-4">
      {chapitresHistoire.map((chapitre) => (
        <a 
          href={chapitre.lien}
          class="block bg-white rounded-xl shadow-lg p-3 sm:p-4 hover:shadow-xl transition-all duration-300"
        >
          <div class="flex items-center space-x-2 sm:space-x-3 mb-1 sm:mb-2">
            <span class="text-xl sm:text-2xl">{chapitre.icone}</span>
            <span class="text-[10px] sm:text-xs font-semibold text-orange-600">{chapitre.periode}</span>
          </div>
          <h4 class="text-sm sm:text-base font-bold text-gray-800">{chapitre.titre}</h4>
        </a>
      ))}
    </div>

    <!-- Bouton pour voir toute l'histoire -->
    <div class="text-center mt-6 sm:mt-8 md:mt-10 lg:mt-12">
      <a 
        href="/histoire" 
        class="inline-flex items-center bg-gradient-to-r from-orange-600 to-red-600 text-white px-5 sm:px-6 md:px-8 py-2.5 sm:py-3 md:py-4 rounded-xl sm:rounded-2xl font-semibold hover:shadow-xl transform hover:scale-105 transition-all duration-300 text-sm sm:text-base"
      >
        Découvrir toute l'histoire
        <svg class="w-4 sm:w-5 h-4 sm:h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>