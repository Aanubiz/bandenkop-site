---
// src/components/CultureSection.astro
const elementsCulturels = [
  {
    categorie: "Danses",
    description: "Les danses traditionnelles qui rythment la vie du village",
    iconeSVG: "/icons/tam-tam.svg",
    lien: "/culture#danses",
    elements: ["Danse des notables - Le Nkah", "Danse des femmes - Le Mfeh", "Danse guerrière - Le Khe", "Danse d'initiation - Le Mengo"],
    couleur: "from-orange-500 to-red-500",
  },
  {
    categorie: "Notabilité",
    description: "L'organisation sociale et le système de chefferie",
    iconeSVG: "/icons/notable.svg",
    lien: "/culture#notabilite",
    elements: ["Le chef et sa cour", "Les neuf notables", "Les chefs de quartier", "Les dignitaires religieux"],
    couleur: "from-yellow-500 to-amber-500",
  },
  {
    categorie: "Chapeaux",
    description: "La symbolique des couvre-chefs traditionnels",
    icone: "🎩",
    lien: "/culture#chapeaux",
    elements: ["Le Tchagha - chapeau royal", "Le Mfo - chapeau des notables", "Le Nkap - chapeau des guerriers", "Le Ndeng - chapeau des sages"],
    couleur: "from-green-500 to-emerald-500",
  },
  {
    categorie: "Chaises",
    description: "Les sièges qui racontent le statut social",
    iconeSVG: "/icons/chaise.svg",
    lien: "/culture#chaises",
    elements: ["Trône royal - Le Kpu", "Chaise à porteur - Le Tchop", "Tabouret des notables - Le Ngong", "Chaise des anciens - Le Foh"],
    couleur: "from-blue-500 to-indigo-500",
  },
  {
    categorie: "Cérémonies",
    description: "Les grands moments de la vie communautaire",
    iconeSVG: "/icons/celebration.svg",
    lien: "/culture#ceremonies",
    elements: ["Intronisation du chef", "Funérailles des notables", "Cérémonies de récolte", "Rituels de purification"],
    couleur: "from-purple-500 to-pink-500",
  },
  {
    categorie: "Initiation",
    description: "Les passages vers la connaissance",
    icone: "🔮",
    lien: "/culture#initiation",
    elements: ["Initiation du Khe", "Société secrète du Ngi", "Initiation des femmes", "Apprentissage des traditions"],
    couleur: "from-red-500 to-pink-500",
  },
  {
    categorie: "Le Khé",
    description: "La quête de la vérité et de la justice",
    icone: "⚖️",
    lien: "/culture#khe",
    elements: ["Le jugement par le poison", "Les ordalies", "La divination", "Les serments"],
    couleur: "from-indigo-500 to-blue-500",
  },
  {
    categorie: "Prophètes",
    description: "Les hommes de Dieu et voyants",
    iconeSVG: "/icons/prophete.svg",
    lien: "/culture#prophetes",
    elements: ["Les marabouts traditionnels", "Les devins-guérisseurs", "Les prophètes modernes", "Les interprètes des signes"],
    couleur: "from-teal-500 to-cyan-500",
  },
];
---

<section class="py-8 sm:py-12 md:py-16 lg:py-20 bg-white">
  <div class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
    <div class="text-center mb-6 sm:mb-8 md:mb-10 lg:mb-12">
      <h2 class="font-['Playfair_Display'] text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-black mb-3 sm:mb-4">
        Notre <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-600 to-red-600">Culture</span>
      </h2>
      <p class="text-sm sm:text-base md:text-lg text-gray-600 max-w-3xl mx-auto px-4">
        Plongez dans la richesse et la diversité des traditions Bandenkop
      </p>
    </div>

    <!-- Grille culturelle -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3 sm:gap-4 md:gap-5 lg:gap-6">
      {
        elementsCulturels.map((element, index) => (
          <a
            href={element.lien}
            class="group relative bg-white rounded-xl sm:rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transform hover:scale-[1.02] transition-all duration-500"
          >
            <div class={`absolute inset-0 bg-gradient-to-br ${element.couleur} opacity-0 group-hover:opacity-10 transition-opacity duration-300`} />

            <div class="p-4 sm:p-5 md:p-6">
              {element.iconeSVG ? (
                <img
                  src={element.iconeSVG}
                  alt={element.categorie}
                  class="w-12 h-12 sm:w-14 sm:h-14 md:w-16 md:h-16 mb-2 sm:mb-3 md:mb-4 transform group-hover:scale-110 group-hover:rotate-6 transition-all duration-300"
                />
              ) : (
                <span class="text-3xl sm:text-4xl md:text-5xl mb-2 sm:mb-3 md:mb-4 transform group-hover:scale-110 group-hover:rotate-6 transition-all duration-300">
                  {element.icone}
                </span>
              )}

              <h3 class="text-base sm:text-lg md:text-xl lg:text-2xl font-bold text-gray-800 mb-1 sm:mb-2">{element.categorie}</h3>

              <p class="text-xs sm:text-sm text-gray-600 mb-2 sm:mb-3 md:mb-4">{element.description}</p>

              <ul class="space-y-1 sm:space-y-2 mb-3 sm:mb-4">
                {element.elements.slice(0, 2).map((item) => (
                  <li class="flex items-start space-x-1 sm:space-x-2 text-xs sm:text-sm">
                    <svg class="w-3 h-3 sm:w-4 sm:h-4 text-orange-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span class="text-gray-600">{item}</span>
                  </li>
                ))}
                <li class="text-xs sm:text-sm text-gray-500 italic">...</li>
              </ul>

              <span class="inline-flex items-center text-orange-600 font-semibold hover:text-orange-800 transition-colors text-xs sm:text-sm">
                En savoir plus
                <svg class="w-3 h-3 sm:w-4 sm:h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>

    <!-- Section spéciale : Les jours de la semaine -->
    <div class="mt-8 sm:mt-10 md:mt-12 lg:mt-16 bg-gradient-to-r from-orange-100 to-red-100 rounded-2xl sm:rounded-3xl p-4 sm:p-5 md:p-6 lg:p-8">
      <h3 class="text-lg sm:text-xl md:text-2xl lg:text-3xl font-bold text-center text-gray-800 mb-4 sm:mb-5 md:mb-6">Les Jours de la Semaine</h3>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 sm:gap-3 md:gap-4">
        <a href="/culture#jours" class="bg-white rounded-lg sm:rounded-xl p-2 sm:p-3 md:p-4 text-center hover:shadow-lg transition-all duration-300">
          <span class="text-xl sm:text-2xl md:text-3xl block mb-1">🌞</span>
          <h4 class="text-xs sm:text-sm font-bold text-gray-800">Liegang</h4>
          <p class="text-[10px] sm:text-xs text-gray-600">Jour du marché</p>
        </a>
        <a href="/culture#jours" class="bg-white rounded-lg sm:rounded-xl p-2 sm:p-3 md:p-4 text-center hover:shadow-lg transition-all duration-300">
          <span class="text-xl sm:text-2xl md:text-3xl block mb-1">🌅</span>
          <h4 class="text-xs sm:text-sm font-bold text-gray-800">Liekwong</h4>
          <p class="text-[10px] sm:text-xs text-gray-600">Jour de festivité</p>
        </a>
        <a href="/culture#jours" class="bg-white rounded-lg sm:rounded-xl p-2 sm:p-3 md:p-4 text-center hover:shadow-lg transition-all duration-300">
          <span class="text-xl sm:text-2xl md:text-3xl block mb-1">🌄</span>
          <h4 class="text-xs sm:text-sm font-bold text-gray-800">Cheptéh</h4>
          <p class="text-[10px] sm:text-xs text-gray-600">Jour interdit</p>
        </a>
        <a href="/culture#jours" class="bg-white rounded-lg sm:rounded-xl p-2 sm:p-3 md:p-4 text-center hover:shadow-lg transition-all duration-300">
          <span class="text-xl sm:text-2xl md:text-3xl block mb-1">🌙</span>
          <h4 class="text-xs sm:text-sm font-bold text-gray-800">Kouohgouè</h4>
          <p class="text-[10px] sm:text-xs text-gray-600">Jour de travail</p>
        </a>
        <a href="/culture#jours" class="bg-white rounded-lg sm:rounded-xl p-2 sm:p-3 md:p-4 text-center hover:shadow-lg transition-all duration-300">
          <span class="text-xl sm:text-2xl md:text-3xl block mb-1">🌙</span>
          <h4 class="text-xs sm:text-sm font-bold text-gray-800">Dzèsseuh</h4>
          <p class="text-[10px] sm:text-xs text-gray-600">Jour de travail</p>
        </a>
        <a href="/culture#jours" class="bg-white rounded-lg sm:rounded-xl p-2 sm:p-3 md:p-4 text-center hover:shadow-lg transition-all duration-300">
          <span class="text-xl sm:text-2xl md:text-3xl block mb-1">🌙</span>
          <h4 class="text-xs sm:text-sm font-bold text-gray-800">Liedjou</h4>
          <p class="text-[10px] sm:text-xs text-gray-600">Jour de travail</p>
        </a>
        <a href="/culture#jours" class="bg-white rounded-lg sm:rounded-xl p-2 sm:p-3 md:p-4 text-center hover:shadow-lg transition-all duration-300">
          <span class="text-xl sm:text-2xl md:text-3xl block mb-1">🌙</span>
          <h4 class="text-xs sm:text-sm font-bold text-gray-800">Temgou</h4>
          <p class="text-[10px] sm:text-xs text-gray-600">Jour de travail</p>
        </a>
        <a href="/culture#jours" class="bg-white rounded-lg sm:rounded-xl p-2 sm:p-3 md:p-4 text-center hover:shadow-lg transition-all duration-300">
          <span class="text-xl sm:text-2xl md:text-3xl block mb-1">🌙</span>
          <h4 class="text-xs sm:text-sm font-bold text-gray-800">Kouohgouè</h4>
          <p class="text-[10px] sm:text-xs text-gray-600">Jour de travail</p>
        </a>
      </div>
    </div>

    <!-- Section Divinité -->
    <div class="mt-8 sm:mt-10 md:mt-12 lg:mt-16 text-center">
      <a
        href="/culture#divinite"
        class="inline-block bg-white rounded-xl sm:rounded-2xl shadow-lg hover:shadow-xl p-4 sm:p-5 md:p-6 lg:p-8 max-w-2xl transition-all duration-300"
      >
        <span class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl block mb-2 sm:mb-3 md:mb-4">🙏</span>
        <h3 class="text-lg sm:text-xl md:text-2xl lg:text-3xl font-bold text-gray-800 mb-2 sm:mb-3">La Divinité - Sieh</h3>
        <p class="text-xs sm:text-sm md:text-base text-gray-600 leading-relaxed">Le Sieh est la force suprême, le créateur de toutes choses...</p>
        <span class="inline-flex items-center text-orange-600 font-semibold mt-3 sm:mt-4 text-xs sm:text-sm">
          En savoir plus
          <svg class="w-3 h-3 sm:w-4 sm:h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>
