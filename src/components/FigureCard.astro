---
interface Figure {
  _id: string;
  slug?: string;
  prenom: string;
  nom: string;
  photo: string;
  resume: string;
  biographie: string;
  likes?: number;
  dislikes?: number;
  contributions?: string[];
  citations?: string[];
}

const { figure, categorie } = Astro.props as { figure: Figure; categorie: string };
const slug = figure.slug || `${figure.prenom}-${figure.nom}`.toLowerCase().replace(/\s+/g, '-');
---

<div class="group relative bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-500">
  <!-- Image -->
  <div class="relative h-64 overflow-hidden">
    <img 
      src={figure.photo} 
      alt={`${figure.prenom} ${figure.nom}`} 
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
      onerror="this.src='/images/default-avatar.png'"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
    
    <!-- Badge de catégorie -->
    <div class="absolute top-4 right-4">
      <span class="px-3 py-1 rounded-full text-xs font-semibold text-white"
        style="background: linear-gradient(135deg, #f97316, #dc2626)">
        {categorie === 'vivants' ? '🌟 Vivant' : categorie === 'traces' ? '📜 Historique' : '⭐ Étoile montante'}
      </span>
    </div>
    
    <!-- Nom en bas de l'image -->
    <div class="absolute bottom-4 left-4 right-4">
      <h3 class="text-xl font-bold text-white mb-1">{figure.prenom} {figure.nom}</h3>
      <p class="text-sm text-orange-200 line-clamp-2">{figure.resume}</p>
    </div>
  </div>
  
  <!-- Contenu expansible -->
  <div class="p-4">
    <div class="flex items-center justify-between mb-3">
      <div class="flex items-center space-x-3">
        <button class="flex items-center space-x-1 text-gray-500 hover:text-red-500 transition-colors" data-id={figure._id} data-type="like">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
          </svg>
          <span id={`likes-${figure._id}`}>{figure.likes || 0}</span>
        </button>
        <button class="flex items-center space-x-1 text-gray-500 hover:text-gray-700 transition-colors" data-id={figure._id} data-type="dislike">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4m16 0l-4-4m4 4l-4 4"></path>
          </svg>
          <span id={`dislikes-${figure._id}`}>{figure.dislikes || 0}</span>
        </button>
      </div>
      <button class="text-orange-600 text-sm font-medium hover:text-orange-800 expand-btn" data-id={figure._id}>
        Lire la suite
        <svg class="w-4 h-4 inline-block ml-1 expand-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </button>
    </div>
    
    <!-- Biographie (cachée par défaut) -->
    <div id={`bio-${figure._id}`} class="hidden mt-3 pt-3 border-t border-gray-100">
      <div class="prose prose-sm max-w-none">
        <p class="text-gray-700 text-sm leading-relaxed">{figure.biographie}</p>
        
        {figure.contributions && figure.contributions.length > 0 && (
          <>
            <h4 class="text-sm font-semibold text-gray-800 mt-3 mb-2">Contributions :</h4>
            <ul class="list-disc list-inside text-xs text-gray-600 space-y-1">
              {figure.contributions.map((contrib: string) => (
                <li>{contrib}</li>
              ))}
            </ul>
          </>
        )}
        
        {figure.citations && figure.citations.length > 0 && (
          <>
            <h4 class="text-sm font-semibold text-gray-800 mt-3 mb-2">Citations :</h4>
            {figure.citations.map((citation: string) => (
              <blockquote class="italic text-xs text-gray-600 border-l-2 border-orange-300 pl-3 my-2">
                "{citation}"
              </blockquote>
            ))}
          </>
        )}
        
        <a href={`/wiki/${slug}`} class="inline-block mt-3 text-orange-600 text-sm font-medium hover:text-orange-800">
          Voir la page complète →
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  // Gestion de l'expansion
  document.querySelectorAll('.expand-btn').forEach((btn) => {
    const button = btn as HTMLButtonElement;

    button.addEventListener('click', (e) => {
      e.preventDefault();
      const id = button.dataset.id;
      if (!id) return;

      const bio = document.getElementById(`bio-${id}`);
      const icon = button.querySelector('.expand-icon') as HTMLElement | null;
      if (!bio || !icon) return;
      
      if (bio.classList.contains('hidden')) {
        bio.classList.remove('hidden');
        icon.style.transform = 'rotate(180deg)';
        button.innerHTML = 'Réduire <svg class="w-4 h-4 inline-block ml-1 expand-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path></svg>';
        const newIcon = button.querySelector('.expand-icon') as HTMLElement | null;
        if (newIcon) newIcon.style.transform = 'rotate(0)';
      } else {
        bio.classList.add('hidden');
        button.innerHTML = 'Lire la suite <svg class="w-4 h-4 inline-block ml-1 expand-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>';
      }
    });
  });

  // Gestion des likes/dislikes
  async function updateVote(figureId: string, type: 'like' | 'dislike') {
    const token = localStorage.getItem('token');
    if (!token) {
      window.location.href = '/connexion?redirect=' + window.location.pathname;
      return;
    }
    
    try {
      const response = await fetch(`http://localhost:3001/api/figures/${figureId}/${type}`, {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        }
      });
      
      const data = await response.json();
      
      // Mettre à jour l'affichage
      const likesEl = document.getElementById(`likes-${figureId}`);
      const dislikesEl = document.getElementById(`dislikes-${figureId}`);
      if (likesEl) likesEl.textContent = String(data.likes ?? 0);
      if (dislikesEl) dislikesEl.textContent = String(data.dislikes ?? 0);
    } catch (error) {
      console.error('Erreur vote:', error);
    }
  }
  
  document.querySelectorAll('[data-type="like"]').forEach((btn) => {
    const button = btn as HTMLButtonElement;
    button.addEventListener('click', () => {
      const id = button.dataset.id;
      if (!id) return;
      updateVote(id, 'like');
    });
  });
  
  document.querySelectorAll('[data-type="dislike"]').forEach((btn) => {
    const button = btn as HTMLButtonElement;
    button.addEventListener('click', () => {
      const id = button.dataset.id;
      if (!id) return;
      updateVote(id, 'dislike');
    });
  });
</script>