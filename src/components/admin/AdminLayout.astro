  <!-- Contenu principal -->
  <main class="ml-64">
    <header class="bg-white shadow-sm sticky top-0 z-30">
      <div class="px-8 h-16 flex items-center justify-between">
        <h1 class="text-xl font-semibold text-gray-800">{title || 'Administration'}</h1>
        <div class="flex items-center space-x-4">
          <a href="/admin" class="inline-flex items-center gap-1 text-sm text-orange-600 hover:text-orange-800 transition-colors font-medium">
            ← Panneau admin
          </a>
          <span class="text-gray-300 select-none">|</span>
          <button id="logout-btn" class="text-red-600 hover:text-red-800 text-sm font-medium">
            Déconnexion
          </button>
        </div>
      </div>
    </header>

    <div class="p-8">
      <slot />
    </div>
  </main>
</div>

<script>
  import { logout } from '../../utils/auth';

  const readJwtPayload = () => {
    try {
      const token = localStorage.getItem('token');
      if (!token) return null;
      return JSON.parse(atob(token.split('.')[1]));
    } catch {
      return null;
    }
  };

  const applyAdminVisibility = () => {
    const payload = readJwtPayload();
    const scope = payload?.adminScope || 'super';
    const perms = Array.isArray(payload?.adminPermissions) ? payload.adminPermissions : [];

    if (scope === 'super') return;

    document.querySelectorAll('[data-admin-resource]').forEach((el) => {
      const resource = el.getAttribute('data-admin-resource');
      const canView = perms.includes(`${resource}:view`) || perms.includes(`${resource}:edit`);
      if (!canView) {
        el.classList.add('hidden');
      }
    });
  };

  applyAdminVisibility();
  document.getElementById('logout-btn')?.addEventListener('click', logout);
</script>