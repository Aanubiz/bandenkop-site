---
const { rubrique = 'general' } = Astro.props;

const quartiers = [
  { 
    nom: 'Denkeng', 
    couleur: 'from-emerald-500 to-emerald-600', 
    bg: 'bg-emerald-50', 
    texte: 'text-emerald-700',
    point: 'bg-emerald-500'
  },
  { 
    nom: 'Tsèmeuhia', 
    couleur: 'from-orange-500 to-orange-600', 
    bg: 'bg-orange-50', 
    texte: 'text-orange-700',
    point: 'bg-orange-500'
  },
  { 
    nom: 'Tsèla', 
    couleur: 'from-blue-700 to-blue-800', 
    bg: 'bg-blue-50', 
    texte: 'text-blue-800',
    point: 'bg-blue-700'
  }
];
---

<div class="bg-white rounded-2xl shadow-xl p-4 sm:p-6 mb-8">
  <!-- En-tête -->
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg sm:text-xl font-bold text-gray-800 flex items-center">
      <svg class="w-5 h-5 sm:w-6 sm:h-6 text-orange-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
      </svg>
      Performance par quartiers
    </h2>
    <span class="text-xs sm:text-sm text-gray-500" id="last-update">Mise à jour en direct</span>
  </div>

  <!-- Barres de progression des quartiers -->
  <div class="space-y-4 mb-6" id="quartier-stats">
    {quartiers.map((quartier, index) => (
      <div class="space-y-2" id={`quartier-${quartier.nom}`}>
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-2">
            <!-- Point coloré -->
            <span class={`w-3 h-3 rounded-full ${quartier.point}`}></span>
            <span class="font-medium text-gray-800">{quartier.nom}</span>
          </div>
          <div class="flex items-center space-x-3">
            <span class="text-sm font-bold text-orange-600" id={`points-${quartier.nom}`}>0</span>
            <span class="text-xs text-gray-500">pts</span>
            <span class="text-xs bg-gray-100 px-2 py-1 rounded-full" id={`membres-${quartier.nom}`}>0</span>
          </div>
        </div>
        <div class="relative h-2.5 bg-gray-200 rounded-full overflow-hidden">
          <div class={`absolute top-0 left-0 h-full bg-gradient-to-r ${quartier.couleur} rounded-full transition-all duration-1000`} 
               id={`barre-${quartier.nom}`} 
               style="width: 0%"></div>
        </div>
      </div>
    ))}
  </div>

  <!-- Top 3 du jour -->
  <div class="border-t border-gray-100 pt-4">
    <h3 class="text-sm font-semibold text-gray-700 mb-3 flex items-center">
      <span class="text-lg mr-1">🏆</span> Top 3
    </h3>
    <div class="space-y-2" id="top-users">
      <!-- Rempli par JavaScript -->
      <div class="text-center text-gray-500 text-sm py-2">Chargement...</div>
    </div>
  </div>

  <!-- Lien vers classement complet -->
  <a href="/classement" class="mt-4 inline-flex items-center text-sm text-orange-600 hover:text-orange-800 font-medium">
    Voir le classement complet
    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
    </svg>
  </a>
</div>

<script>
  import { getApiUrl } from '../../config';

  const API_URL = getApiUrl();

  // Fonction pour charger les stats des quartiers
  async function chargerClassementQuartiers() {
    try {
      const token = localStorage.getItem('token');
      if (!token) return;

      const response = await fetch(`${API_URL}/api/classement/quartiers`, {
        headers: {
          'Authorization': `Bearer ${token}`
        }
      });

      if (!response.ok) throw new Error('Erreur chargement');

      const data = await response.json();
      
      // Trouver le score maximum pour les barres de progression
      const maxPoints = Math.max(...data.quartiers.map((q: any) => q.points));
      
      // Mettre à jour chaque quartier
      data.quartiers.forEach((quartier: any) => {
        const pointsEl = document.getElementById(`points-${quartier.nom}`);
        const membresEl = document.getElementById(`membres-${quartier.nom}`);
        const barreEl = document.getElementById(`barre-${quartier.nom}`);
        
        if (pointsEl) pointsEl.textContent = quartier.points;
        if (membresEl) membresEl.textContent = quartier.membres;
        if (barreEl) {
          const pourcentage = maxPoints > 0 ? (quartier.points / maxPoints) * 100 : 0;
          barreEl.style.width = `${pourcentage}%`;
        }
      });

      // Mettre à jour le top 3 du jour
      const topUsersEl = document.getElementById('top-users');
      if (topUsersEl && data.top3) {
        topUsersEl.innerHTML = data.top3.map((user: any, index: number) => {
          // Déterminer la couleur du badge selon le quartier
          let badgeColor = '';
          if (user.quartier === 'Denkeng') badgeColor = 'bg-emerald-100 text-emerald-800';
          else if (user.quartier === 'Tsèmeuhia') badgeColor = 'bg-orange-100 text-orange-800';
          else if (user.quartier === 'Tsèla') badgeColor = 'bg-blue-100 text-blue-800';
          
          return `
            <div class="flex items-center justify-between py-2 px-3 ${index === 0 ? 'bg-yellow-50' : index === 1 ? 'bg-gray-50' : 'bg-orange-50'} rounded-lg">
              <div class="flex items-center space-x-3">
                <span class="text-sm font-bold ${index === 0 ? 'text-yellow-600' : index === 1 ? 'text-gray-600' : 'text-orange-600'}">
                  #{index + 1}
                </span>
                <span class="text-sm font-medium text-gray-800">${user.prenom} ${user.nom}</span>
                <span class="text-xs px-2 py-0.5 rounded-full ${badgeColor}">
                  ${user.quartier}
                </span>
              </div>
              <span class="text-sm font-bold text-orange-600">${user.points} pts</span>
            </div>
          `;
        }).join('');
      }

      // Mettre à jour l'heure
      const updateEl = document.getElementById('last-update');
      if (updateEl) {
        const now = new Date();
        updateEl.textContent = `Dernière mise à jour : ${now.getHours()}:${now.getMinutes().toString().padStart(2, '0')}`;
      }

    } catch (error) {
      console.error('Erreur chargement classement:', error);
    }
  }

  // Charger au chargement de la page
  document.addEventListener('DOMContentLoaded', chargerClassementQuartiers);
  
  // Recharger toutes les 30 secondes
  setInterval(chargerClassementQuartiers, 30000);
</script>