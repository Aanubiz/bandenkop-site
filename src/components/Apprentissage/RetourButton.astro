---
const { 
  url = '/apprentissage',
  className = ''
} = Astro.props;
---

<a 
  href={url}
  class={`inline-flex items-center text-gray-600 hover:text-orange-600 transition-colors group min-h-[44px] px-2 -ml-2 ${className}`}
  aria-label="Retour"
>
  <svg class="w-5 h-5 mr-1 sm:mr-2 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
  </svg>
  <span class="hidden sm:inline text-sm font-medium">Retour à l'apprentissage</span>
  <span class="sm:hidden text-sm font-medium">Retour</span>
</a>