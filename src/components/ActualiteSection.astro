---
// src/components/ActualiteSection.astro
const articles = [
  {
    id: 1,
    titre: "Les frontières de Bandenkop, les jeunes s'interrogent",
    date: "15 Février 2026",
    categorie: "Développement",
    image: "/images/actualites/carte-bandenkop.png",
    resume: "Un nouveau centre dédié à la préservation et à la transmission de la culture Bandenkop ouvre ses portes.",
    auteur: "Comité de Développement",
    lien: "/actualite#centre-culturel"
  },
  {
    id: 2,
    titre: "Relance du centre de formation professionnelle de Bandenkop",
    date: "10 Octobre 2025",
    categorie: "Développement",
    image: "/images/actualites/centre.jpeg",
    resume: "La communauté s'est réunie pour célébrer les récoltes dans la joie et la tradition.",
    auteur: "Notable Tchomgou",
    lien: "/actualite#fete-recoltes"
  },
  {
    id: 3,
    titre: "Etrange danse kougangà Bandenkop",
    date: "5 Mars 2026",
    categorie: "Développement",
    image: "/images/actualites/kougang.jpeg",
    resume: "Un nouveau projet vise à améliorer l'accès à l'eau potable dans tout le village.",
    auteur: "Chef de Projet",
    lien: "/actualite#eau-potable"
  },
  {
    id: 4,
    titre: "Rencontre de la diaspora à Paris",
    date: "1 Mars 2026",
    categorie: "Diaspora",
    image: "/images/actualites/diaspora-paris.jpg",
    resume: "Les Bandenkop d'Europe se sont réunis pour renforcer les liens avec la terre natale.",
    auteur: "Association Bandenkop Europe",
    lien: "/actualite#diaspora"
  }
];
---

<section class="py-8 sm:py-12 md:py-16 lg:py-20 bg-gray-50">
  <div class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
    <div class="text-center mb-6 sm:mb-8 md:mb-10 lg:mb-12">
      <h2 class="font-['Playfair_Display'] text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-black mb-3 sm:mb-4">
        Actualités <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-600 to-red-600">Bandenkop</span>
      </h2>
      <p class="text-sm sm:text-base md:text-lg text-gray-600 max-w-2xl mx-auto">
        Restez informé des dernières nouvelles de la communauté
      </p>
    </div>

    <!-- Articles principaux -->
    <div class="grid md:grid-cols-2 gap-4 sm:gap-5 md:gap-6 lg:gap-8 mb-4 sm:mb-5 md:mb-6">
      {articles.slice(0, 2).map((article) => (
        <a 
          href={article.lien}
          class="group bg-white rounded-xl sm:rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transform hover:scale-[1.02] transition-all duration-500"
        >
          <div class="relative h-40 sm:h-48 md:h-56 overflow-hidden">
            <img src={article.image} alt={article.titre} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
            <div class="absolute top-2 sm:top-3 md:top-4 left-2 sm:left-3 md:left-4">
              <span class="bg-orange-600 text-white px-2 sm:px-3 py-0.5 sm:py-1 rounded-full text-[10px] sm:text-xs font-semibold">
                {article.categorie}
              </span>
            </div>
          </div>
          <div class="p-3 sm:p-4 md:p-5 lg:p-6">
            <div class="flex items-center text-[10px] sm:text-xs text-gray-500 mb-1 sm:mb-2">
              <span>{article.date}</span>
              <span class="mx-1 sm:mx-2">•</span>
              <span>Par {article.auteur}</span>
            </div>
            <h3 class="text-sm sm:text-base md:text-lg lg:text-xl font-bold text-gray-800 mb-1 sm:mb-2">{article.titre}</h3>
            <p class="text-xs sm:text-sm text-gray-600 mb-2 sm:mb-3 line-clamp-2">{article.resume}</p>
            <span class="inline-flex items-center text-orange-600 font-semibold hover:text-orange-800 transition-colors text-xs sm:text-sm">
              Lire l'article complet
              <svg class="w-3 h-3 sm:w-4 sm:h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- Articles secondaires -->
    <div class="grid sm:grid-cols-2 gap-3 sm:gap-4 md:gap-5 lg:gap-6">
      {articles.slice(2, 4).map((article) => (
        <a 
          href={article.lien}
          class="group bg-white rounded-lg sm:rounded-xl shadow hover:shadow-lg transition-all duration-300 flex overflow-hidden"
        >
          <div class="w-1/3">
            <img src={article.image} alt={article.titre} class="w-full h-full object-cover" />
          </div>
          <div class="w-2/3 p-2 sm:p-3 md:p-4">
            <div class="flex items-center text-[8px] sm:text-[10px] md:text-xs text-gray-500 mb-0.5 sm:mb-1">
              <span>{article.date}</span>
              <span class="mx-0.5 sm:mx-1">•</span>
              <span class="bg-orange-100 text-orange-800 px-1 sm:px-2 py-0.5 rounded-full">
                {article.categorie}
              </span>
            </div>
            <h4 class="text-xs sm:text-sm font-bold text-gray-800 mb-0.5 sm:mb-1 line-clamp-1">{article.titre}</h4>
            <p class="text-[10px] sm:text-xs text-gray-600 mb-1 sm:mb-2 line-clamp-2">{article.resume}</p>
            <span class="text-orange-600 text-[10px] sm:text-xs font-semibold hover:text-orange-800">
              Lire →
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- Bouton voir toutes les actualités -->
    <div class="text-center mt-6 sm:mt-8 md:mt-10 lg:mt-12">
      <a 
        href="/actualite" 
        class="inline-flex items-center bg-gradient-to-r from-orange-600 to-red-600 text-white px-5 sm:px-6 md:px-8 py-2.5 sm:py-3 md:py-4 rounded-xl sm:rounded-2xl font-semibold hover:shadow-xl transform hover:scale-105 transition-all duration-300 text-sm sm:text-base"
      >
        Voir toutes les actualités
        <svg class="w-4 sm:w-5 h-4 sm:h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </a>
    </div>
  </div>
</section>