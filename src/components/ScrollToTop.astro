---
// src/components/ScrollToTop.astro (version épurée)
---

<div class="fixed bottom-20 sm:bottom-8 right-4 sm:right-8 z-50" id="scrollToTopContainer">
  <!-- Bouton avec progression intégrée -->
  <button 
    id="scrollToTopBtn"
    class="relative w-12 h-12 sm:w-14 sm:h-14 rounded-full shadow-xl hover:shadow-2xl transform hover:scale-110 transition-all duration-300 opacity-0 invisible focus:outline-none focus:ring-2 focus:ring-orange-400 focus:ring-offset-2"
    aria-label="Retour en haut"
  >
    <!-- Cercle de progression (arrière-plan) -->
    <svg class="absolute inset-0 w-full h-full transform -rotate-90">
      <circle
        cx="50%"
        cy="50%"
        r="22"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        class="text-gray-200/80"
      />
      <circle
        id="progressCircle"
        cx="50%"
        cy="50%"
        r="22"
        fill="none"
        stroke="currentColor"
        stroke-width="3"
        stroke-dasharray="138"
        stroke-dashoffset="138"
        class="text-orange-600 transition-all duration-300"
        style="stroke-dashoffset: 138; stroke-linecap: round;"
      />
    </svg>
    
    <!-- Fond dégradé du bouton -->
    <div class="absolute inset-1 bg-gradient-to-br from-orange-600 to-red-600 rounded-full flex items-center justify-center">
      <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
      </svg>
    </div>
    
    <!-- Tooltip sur desktop -->
    <span class="absolute -top-10 left-1/2 transform -translate-x-1/2 bg-gray-900 text-white text-xs py-2 px-3 rounded-xl opacity-0 group-hover:opacity-100 transition-all duration-300 whitespace-nowrap pointer-events-none hidden sm:block shadow-lg">
      Retour en haut
      <span class="absolute bottom-0 left-1/2 transform -translate-x-1/2 translate-y-1/2 rotate-45 w-2 h-2 bg-gray-900"></span>
    </span>
  </button>
</div>

<style>
  #scrollToTopBtn {
    transition: opacity 0.3s ease-in-out, transform 0.3s ease-in-out, visibility 0.3s ease-in-out;
  }

  #scrollToTopBtn:hover {
    animation: gentlePulse 2s infinite;
  }

  @keyframes gentlePulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.08); }
  }

  #scrollToTopBtn span {
    transition: opacity 0.2s ease-in-out, transform 0.2s ease-in-out;
  }

  #scrollToTopBtn:hover span {
    opacity: 1;
    transform: translateX(-50%) translateY(-2px);
  }

  @media (max-width: 640px) {
    #scrollToTopContainer {
      bottom: 5rem;
    }
  }

  @media (max-width: 360px) {
    #scrollToTopContainer {
      right: 0.75rem;
    }
    
    #scrollToTopBtn {
      width: 2.5rem;
      height: 2.5rem;
    }
    
    .absolute.inset-1 svg {
      width: 1rem;
      height: 1rem;
    }
    
    svg circle {
      r: 18;
    }
  }
</style>

<script>
  const scrollToTopBtn = document.getElementById('scrollToTopBtn');
  const progressCircle = document.getElementById('progressCircle');
  let ticking = false;

  function updateProgress() {
    const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
    const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    const scrolled = (winScroll / height) * 100;
    
    if (progressCircle) {
      const circumference = 138;
      const dashOffset = circumference - (scrolled / 100) * circumference;
      progressCircle.style.strokeDashoffset = String(Math.max(0, Math.min(circumference, dashOffset)));
    }

    if (scrollToTopBtn) {
      if (winScroll > 300) {
        if (scrollToTopBtn.classList.contains('invisible')) {
          scrollToTopBtn.classList.remove('opacity-0', 'invisible');
          scrollToTopBtn.classList.add('opacity-100', 'visible');
        }
      } else {
        if (!scrollToTopBtn.classList.contains('invisible')) {
          scrollToTopBtn.classList.add('opacity-0', 'invisible');
          scrollToTopBtn.classList.remove('opacity-100', 'visible');
        }
      }
    }
    
    ticking = false;
  }

  function scrollToTop() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
    // Feedback visuel
    if (scrollToTopBtn) {
      scrollToTopBtn.style.transform = 'scale(0.9)';
      setTimeout(() => {
        scrollToTopBtn.style.transform = 'scale(1)';
      }, 200);
    }
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        updateProgress();
        ticking = false;
      });
      ticking = true;
    }
  });

  if (scrollToTopBtn) {
    scrollToTopBtn.addEventListener('click', scrollToTop);
  }
  updateProgress();
</script>