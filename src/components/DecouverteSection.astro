---
// src/components/DecouverteSection.astro
const lieux = [
  {
    nom: "Loung Beli",
    type: "Relief",
    description: "Paysage de rochers granitiques offrant une vue panoramique sur toute la région",
    image: "/images/decouverte/loung_beli2.jpg",
    coordonnees: "5.1333° N, 10.3833° E"
  },
  {
    nom: "Centre touristique de Bandenkop",
    type: "Tourisme",
    description: "Point culminant à 1800m d'altitude offrant une vue panoramique sur toute la région et les villages environnants",
    image: "/images/decouverte/entree_chefferie.jpg",
    coordonnees: "5.1456° N, 10.3921° E"
  },
  {
    nom: "Chefferie",
    type: "Culture",
    description: "Lieu de résidence de Sa majesté et siège du pouvoir traditionnel.",
    image: "/images/decouverte/visite_chefferie.jpg",
    coordonnees: "5.1311° N, 10.3817° E"
  },
  {
    nom: "Marché",
    type: "Economie",
    description: "Le cœur battant du commerce local tous les Liegang.",
    image: "/images/decouverte/place_marche.jpg",
    coordonnees: "5.1389° N, 10.3785° E"
  }
];
---

<section class="py-20 bg-white">
  <div class="container mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-black text-gray-800 mb-4">
        Découvrez <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-600 to-red-600">Bandenkop</span>
      </h2>
      <p class="text-xl text-gray-600">
        Explorez la géographie, les richesses naturelles et culturelles de notre village
      </p>
    </div>

    <!-- Carte interactive -->
    <div class="relative h-96 mb-12 rounded-2xl overflow-hidden shadow-2xl">
      <img src="/images/decouverte/carte.jpg" alt="Carte de Bandenkop" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
      <div class="absolute bottom-8 left-8 text-white">
        <h3 class="text-3xl font-bold mb-2">Situation Géographique</h3>
        <p class="text-lg">Hauts Plateaux de l'Ouest Cameroun</p>
        <p class="text-sm opacity-75">Arrondissement de Bangou</p>
      </div>
    </div>

    <!-- Grille découverte -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      {lieux.map((lieu) => (
        <div class="group relative bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transform hover:scale-105 transition-all duration-500">
          <div class="relative h-48 overflow-hidden">
            <img src={lieu.image} alt={lieu.nom} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
            <div class="absolute top-4 left-4">
              <span class="bg-orange-600 text-white px-2 py-1 rounded-full text-xs">
                {lieu.type}
              </span>
            </div>
          </div>
          <div class="p-4">
            <h3 class="font-bold text-gray-800 mb-1">{lieu.nom}</h3>
            <p class="text-sm text-gray-600 mb-2">{lieu.description}</p>
            <p class="text-xs text-gray-400">{lieu.coordonnees}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Informations détaillées -->
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-orange-50 rounded-xl p-6">
        <div class="text-3xl mb-3">⛰️</div>
        <h3 class="font-bold text-gray-800 mb-2">Relief et Climat</h3>
        <ul class="space-y-2 text-sm text-gray-600">
          <li>• Altitude : 1400-1800m</li>
          <li>• Climat tropical d'altitude</li>
          <li>• Saison sèche : Nov-Fev</li>
          <li>• Saison pluvieuse : Mars-Oct</li>
          <li>• Température moyenne : 22°C</li>
        </ul>
      </div>

      <div class="bg-green-50 rounded-xl p-6">
        <div class="text-3xl mb-3">🌿</div>
        <h3 class="font-bold text-gray-800 mb-2">Végétation</h3>
        <ul class="space-y-2 text-sm text-gray-600">
          <li>• Savane arbustive</li>
          <li>• Forêts galeries</li>
          <li>• Arbres sacrés (Baobab)</li>
          <li>• Plantes médicinales</li>
          <li>• Cultures en sion</li>
        </ul>
      </div>

      <div class="bg-blue-50 rounded-xl p-6">
        <div class="text-3xl mb-3">💧</div>
        <h3 class="font-bold text-gray-800 mb-2">Hydrographie</h3>
        <ul class="space-y-2 text-sm text-gray-600">
          <li>• Rivière Temmèkouang</li>
          <li>• Rivière Tchoua Tchoua</li>
          <li>• Lac Tcha-Tcha</li>
          <li>• Cascade de Loung Beli</li>
        </ul>
      </div>

      <div class="bg-purple-50 rounded-xl p-6">
        <div class="text-3xl mb-3">🏥</div>
        <h3 class="font-bold text-gray-800 mb-2">Éducation & Santé</h3>
        <ul class="space-y-2 text-sm text-gray-600">
          <li>• Écoles primaires publiques</li>
          <li>• Centres de santé </li>
          <li>• Lycée et collège</li>
          <li>• Centre de formation professionnelle</li>
        </ul>
      </div>

      <div class="bg-red-50 rounded-xl p-6">
        <div class="text-3xl mb-3">⚽</div>
        <h3 class="font-bold text-gray-800 mb-2">Sport</h3>
        <ul class="space-y-2 text-sm text-gray-600">
          <li>• Équipe de football locale (2-0)</li>
          <li>• Équipe de Boxe Anglaise</li>
        </ul>
      </div>

      <div class="bg-yellow-50 rounded-xl p-6">
        <div class="text-3xl mb-3">🎪</div>
        <h3 class="font-bold text-gray-800 mb-2">Festivals</h3>
        <ul class="space-y-2 text-sm text-gray-600">
          <li>• Festival Lah Fé Bouagang </li>
          <li>• Danse initiatique Kang</li>
          <li>• Congrès de la Jeunesse </li>
        </ul>
      </div>
    </div>

    <!-- Activités touristiques -->
    <div class="mt-12 bg-gradient-to-r from-orange-600 to-red-600 rounded-2xl p-8 text-white">
      <h3 class="text-2xl font-bold mb-4">Activités Touristiques</h3>
      <div class="grid md:grid-cols-3 gap-4">
        <div class="flex items-center space-x-3">
          <span class="text-2xl">🥾</span>
          <span>Randonnées guidées</span>
        </div>
        <div class="flex items-center space-x-3">
          <span class="text-2xl">🏕️</span>
          <span>Camping au centre touristique</span>
        </div>
        <div class="flex items-center space-x-3">
          <span class="text-2xl">🎨</span>
          <span>Ateliers d'artisanat</span>
        </div>
        <div class="flex items-center space-x-3">
          <span class="text-2xl">🍲</span>
          <span>Cuisine traditionnelle</span>
        </div>
        <div class="flex items-center space-x-3">
          <span class="text-2xl">🎭</span>
          <span>Spectacles culturels</span>
        </div>
        <div class="flex items-center space-x-3">
          <span class="text-2xl">📸</span>
          <span>Photographie</span>
        </div>
      </div>
    </div>
  </div>
</section>