---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();

const liens = {
  rubriques: ['Histoire', 'Culture', 'Apprentissage', 'Actualités', 'Découverte', 'Projets'],
  legaux: ['Mentions légales', 'Politique de confidentialité', 'CGU', 'Cookies']
};
---

<footer class="bg-gray-900 text-white relative overflow-hidden">
  <!-- Pattern décoratif -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-0 left-0 w-64 h-64 bg-orange-600 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-red-600 rounded-full blur-3xl"></div>
  </div>

  <div class="relative px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
    <!-- Newsletter - avec padding interne -->
    <div class="py-8 sm:py-10 md:py-12 lg:py-16">
      <div class="bg-gradient-to-r from-orange-600 to-red-600 rounded-2xl sm:rounded-3xl p-5 sm:p-6 md:p-8 lg:p-10">
        <div class="grid sm:grid-cols-2 gap-4 sm:gap-6 items-center">
          <div>
            <h3 class="text-lg sm:text-xl md:text-2xl font-bold mb-1 sm:mb-2">Restez connecté</h3>
            <p class="text-xs sm:text-sm md:text-base text-orange-100">
              Recevez les dernières actualités de Bandenkop
            </p>
          </div>
          <form class="flex flex-col sm:flex-row gap-2 sm:gap-3" onsubmit="handleNewsletter(event)">
            <input 
              type="email" 
              placeholder="Votre email" 
              class="flex-1 px-3 sm:px-4 py-2 sm:py-3 bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl text-white placeholder-white/50 text-sm focus:outline-none focus:ring-2 focus:ring-white"
              required
            />
            <button type="submit" class="bg-white text-orange-600 px-4 sm:px-6 py-2 sm:py-3 rounded-xl font-semibold hover:bg-orange-50 transition-colors whitespace-nowrap text-sm">
              S'inscrire
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- Grille de liens - avec padding interne -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 sm:gap-8 pb-8 sm:pb-10 md:pb-12">
      <!-- Logo et description - occupe 2 colonnes sur mobile -->
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center space-x-2 sm:space-x-3 mb-3 sm:mb-4">
          <div class="w-8 h-8 sm:w-10 sm:h-10 bg-gradient-to-br from-orange-600 to-red-600 rounded-lg sm:rounded-xl flex items-center justify-center font-black text-base sm:text-lg">
            B
          </div>
          <span class="text-base sm:text-lg font-black">Bandenkop</span>
        </div>
        <p class="text-xs sm:text-sm text-gray-400 leading-relaxed">
          Village de 2ème degré situé dans l'arrondissement de Bangou, au cœur des Hauts Plateaux de l'Ouest Cameroun.
        </p>
      </div>

      <!-- Rubriques -->
      <div>
        <h4 class="font-bold mb-3 sm:mb-4 text-xs uppercase tracking-wider text-gray-400">Rubriques</h4>
        <ul class="space-y-1.5 sm:space-y-2">
          {liens.rubriques.map((lien) => (
            <li>
              <a href={`/${lien.toLowerCase()}`} class="text-xs sm:text-sm text-gray-300 hover:text-white transition-colors">
                {lien}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Liens légaux -->
      <div>
        <h4 class="font-bold mb-3 sm:mb-4 text-xs uppercase tracking-wider text-gray-400">Informations</h4>
        <ul class="space-y-1.5 sm:space-y-2">
          {liens.legaux.map((lien) => (
            <li>
              <a href="#" class="text-xs sm:text-sm text-gray-300 hover:text-white transition-colors">
                {lien}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="col-span-2 md:col-span-1">
        <h4 class="font-bold mb-3 sm:mb-4 text-xs uppercase tracking-wider text-gray-400">Contact</h4>
        <ul class="space-y-2 sm:space-y-3">
          <li class="flex items-start space-x-2">
            <svg class="w-3 h-3 sm:w-4 sm:h-4 mt-0.5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span class="text-xs sm:text-sm text-gray-300">Bandenkop, Cameroun</span>
          </li>
          <li class="flex items-center space-x-2">
            <svg class="w-3 h-3 sm:w-4 sm:h-4 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <span class="text-xs sm:text-sm text-gray-300">contact@bandenkoponline.com</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Social et copyright - avec padding interne -->
    <div class="py-6 sm:py-8 border-t border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex space-x-3 sm:space-x-4">
        <a href="#" class="w-8 h-8 sm:w-10 sm:h-10 bg-gray-800 rounded-lg sm:rounded-xl flex items-center justify-center hover:bg-orange-600 transition-colors">
          <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <a href="#" class="w-8 h-8 sm:w-10 sm:h-10 bg-gray-800 rounded-lg sm:rounded-xl flex items-center justify-center hover:bg-orange-600 transition-colors">
          <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2H21.5l-7.12 8.138L22.75 22h-6.55l-5.13-6.72L5.2 22H1.94l7.62-8.71L1.5 2h6.72l4.64 6.16L18.244 2Zm-1.15 18h1.81L7.27 3.89H5.33L17.094 20Z"/>
          </svg>
        </a>
        <a href="#" class="w-8 h-8 sm:w-10 sm:h-10 bg-gray-800 rounded-lg sm:rounded-xl flex items-center justify-center hover:bg-orange-600 transition-colors">
          <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2Zm0 1.8A3.95 3.95 0 0 0 3.8 7.75v8.5a3.95 3.95 0 0 0 3.95 3.95h8.5a3.95 3.95 0 0 0 3.95-3.95v-8.5a3.95 3.95 0 0 0-3.95-3.95h-8.5Zm8.95 1.45a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 1.8a3.2 3.2 0 1 0 0 6.4 3.2 3.2 0 0 0 0-6.4Z"/>
          </svg>
        </a>
      </div>
      
      <p class="text-xs sm:text-sm text-gray-400">
        © {currentYear} Bandenkop. Tous droits réservés.
      </p>
    </div>
  </div>
</footer>

<script>
  function handleNewsletter(e: SubmitEvent) {
    e.preventDefault();
    alert('✨ Merci de votre inscription ! Vous recevrez bientôt nos actualités.');
    if (e.target && typeof (e.target as HTMLFormElement).reset === 'function') {
      (e.target as HTMLFormElement).reset();
    }
  }
</script>